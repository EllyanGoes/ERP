// ── Req/Dev de Materiais ──────────────────────────────────────────────────────

model RequisicaoMaterial {
  id                   String                   @id @default(cuid())
  empresaId            String                   @default("emp_tramontin")
  numero               String
  tipo                 TipoRequisicaoMaterial   @default(REQUISICAO)
  status               StatusRequisicaoMaterial @default(RASCUNHO)
  localEstoqueId       String
  // Local de DESTINO opcional: preenchido = atender vira TRANSFERÊNCIA (saída na
  // origem + entrada no destino), não baixa/consumo. Ex.: liberar embalagem do
  // almoxarifado p/ o estoque de produção.
  localDestinoId       String?
  colaboradorId        String?
  setorId              String?
  almoxarifeId         String?
  os                   String?
  centroCustoId        String?
  // Natureza financeira da saída (ex.: CIF → consumo vai p/ "CIF a Apropriar").
  naturezaFinanceiraId String?
  contaContabil        String?
  data                 DateTime                 @default(now())
  observacoes          String?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  localEstoque         LocalEstoque             @relation("RM_LocalOrigem", fields: [localEstoqueId], references: [id])
  localDestino         LocalEstoque?            @relation("RM_LocalDestino", fields: [localDestinoId], references: [id])
  colaborador          Colaborador?             @relation("RM_Solicitante", fields: [colaboradorId], references: [id])
  setor                Setor?                   @relation(fields: [setorId], references: [id])
  almoxarife           Colaborador?             @relation("RM_Almoxarife", fields: [almoxarifeId], references: [id])
  centroCusto          CentroCusto?             @relation(fields: [centroCustoId], references: [id])
  naturezaFinanceira   NaturezaFinanceira?      @relation(fields: [naturezaFinanceiraId], references: [id])
  itens                RequisicaoMaterialItem[]

  empresa       Empresa @relation(fields: [empresaId], references: [id])
  criadoPor     String? // autoria: carimbado automaticamente pelo proxy de sessão
  atualizadoPor String? // autoria: última edição manual (proxy de sessão)

  @@unique([empresaId, numero])
  @@index([status])
  @@index([localEstoqueId])
  @@index([localDestinoId])
  @@index([empresaId])
}

model RequisicaoMaterialItem {
  id                      String              @id @default(cuid())
  requisicaoId            String
  itemId                  String
  quantidade              Decimal             @db.Decimal(15, 3)
  unidade                 String?
  localizacao             String?
  centroCustoId           String?
  // Natureza financeira POR ITEM (gaveta gerencial; vence a do cabeçalho).
  naturezaFinanceiraId    String?
  // Destino contábil MANUAL (escape explícito, independente da natureza): força o
  // destino da linha. Vence as flags do item (exceto material direto). null = automático.
  destinoManual           DestinoConsumo?
  contaContabil           String?
  os                      String?
  requisicaoRef           String?
  // Capitaliza (degrau do meio da precedência): null = herda item.capitaliza; true/
  // false = decisão da LINHA (a mesma peça é capex numa melhoria e opex numa
  // restauração). NÃO é natureza. Quando true, exige imobilizadoId (o bem que recebe
  // o valor). Ver src/lib/pcp/rotear-requisicao.ts.
  capitaliza              Boolean?
  imobilizadoId           String?
  imobilizado             Imobilizado?        @relation("RmItemImobilizado", fields: [imobilizadoId], references: [id])
  // Componente velho a dar baixa (abordagem por componente, CPC 27) quando a
  // capitalização é uma TROCA.
  componenteSubstituidoId String?
  componenteSubstituido   Imobilizado?        @relation("RmItemComponente", fields: [componenteSubstituidoId], references: [id])
  // TES da linha + compoeCusto da linha (null = herda item.compoeCusto).
  tesId                   String?
  tes                     TipoOperacao?       @relation(fields: [tesId], references: [id])
  compoeCusto             Boolean?
  requisicao              RequisicaoMaterial  @relation(fields: [requisicaoId], references: [id], onDelete: Cascade)
  item                    Item                @relation(fields: [itemId], references: [id])
  centroCusto             CentroCusto?        @relation(fields: [centroCustoId], references: [id])
  naturezaFinanceira      NaturezaFinanceira? @relation(fields: [naturezaFinanceiraId], references: [id])

  @@index([requisicaoId])
  @@index([imobilizadoId])
}

// ── Inventário de Materiais ───────────────────────────────────────────────────

model InventarioMaterial {
  id             String                   @id @default(cuid())
  empresaId      String                   @default("emp_tramontin")
  numero         String
  localEstoqueId String
  colaboradorId  String?
  data           DateTime
  tipo           TipoInventarioMaterial   @default(TOTAL)
  status         StatusInventarioMaterial @default(RASCUNHO)
  observacoes    String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  localEstoque   LocalEstoque             @relation(fields: [localEstoqueId], references: [id])
  colaborador    Colaborador?             @relation(fields: [colaboradorId], references: [id])
  itens          InventarioMaterialItem[]

  empresa       Empresa @relation(fields: [empresaId], references: [id])
  criadoPor     String? // autoria: carimbado automaticamente pelo proxy de sessão
  atualizadoPor String? // autoria: última edição manual (proxy de sessão)

  @@unique([empresaId, numero])
  @@index([status])
  @@index([localEstoqueId])
  @@index([empresaId])
}

model InventarioMaterialItem {
  id            String             @id @default(cuid())
  inventarioId  String
  itemId        String
  localizacao   String?
  saldoSistema  Decimal            @db.Decimal(15, 3)
  saldoFisico   Decimal?           @db.Decimal(15, 3)
  diferenca     Decimal?           @db.Decimal(15, 3)
  custoUnitario Decimal?           @db.Decimal(15, 2)
  fornecedorId  String?
  inventario    InventarioMaterial @relation(fields: [inventarioId], references: [id], onDelete: Cascade)
  item          Item               @relation(fields: [itemId], references: [id])
  fornecedor    Fornecedor?        @relation(fields: [fornecedorId], references: [id])

  @@index([inventarioId])
  @@index([fornecedorId])
}

enum TipoMovimentacaoComodato {
  SAIDA
  RETORNO
}

enum OrigemMovimentacaoComodato {
  MANUAL
  AUTOMATICO
}

enum TipoRequisicaoMaterial {
  REQUISICAO
  DEVOLUCAO
}

enum StatusRequisicaoMaterial {
  RASCUNHO
  ABERTA
  ATENDIDA
  CANCELADA
}

enum TipoInventarioMaterial {
  TOTAL
  PARCIAL
  CICLICO
}

enum StatusInventarioMaterial {
  RASCUNHO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

model SupportTicket {
  id              String              @id @default(cuid())
  numero          String              @unique
  titulo          String
  descricao       String
  tipo            TipoSupportTicket   @default(MELHORIA)
  status          StatusSupportTicket @default(ABERTO)
  prioridade      PrioridadeTicket    @default(MEDIA)
  imagemUrl       String?
  imagemNome      String?
  resposta        String?
  usuarioId       String
  respondidoPorId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  usuario         Usuario             @relation("TicketsAbertos", fields: [usuarioId], references: [id])
  respondidoPor   Usuario?            @relation("TicketsRespondidos", fields: [respondidoPorId], references: [id])


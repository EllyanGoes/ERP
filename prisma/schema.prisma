generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AnexoCotacaoFornecedor {
  id                  String            @id @default(cuid())
  cotacaoFornecedorId String
  nome                String
  url                 String
  tamanho             Int
  tipo                String
  createdAt           DateTime          @default(now())
  cotacaoFornecedor   CotacaoFornecedor @relation(fields: [cotacaoFornecedorId], references: [id], onDelete: Cascade)
}

model AprovacaoEtapa {
  id            String         @id @default(cuid())
  fluxoId       String
  ordem         Int
  nome          String?
  valorMin      Decimal?       @db.Decimal(15, 2)
  valorMax      Decimal?       @db.Decimal(15, 2)
  aprovadorId   String?
  createdAt     DateTime       @default(now())
  colaboradorId String?
  aprovador     Usuario?       @relation(fields: [aprovadorId], references: [id])
  colaborador   Colaborador?   @relation(fields: [colaboradorId], references: [id])
  fluxo         AprovacaoFluxo @relation(fields: [fluxoId], references: [id], onDelete: Cascade)
}

model AprovacaoFluxo {
  id           String            @id @default(cuid())
  nome         String
  ativo        Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  processo     ProcessoAprovacao @default(SOLICITACAO_COMPRAS)
  etapas       AprovacaoEtapa[]
  aprovacoesSC AprovacaoSC[]
}

model AprovacaoSC {
  id            String            @id @default(cuid())
  necessidadeId String?
  cotacaoId     String?
  etapaOrdem    Int
  etapaNome     String?
  aprovadorId   String
  status        StatusAprovacao   @default(PENDENTE)
  observacao    String?
  respondidoEm  DateTime?
  waMsgId       String?
  // Mensagem do Telegram enviada ao aprovador (DM) — guardada p/ editar ao
  // aprovar/reprovar (novo status, sem botões).
  telegramChatId String?
  telegramMsgId  Int?
  createdAt     DateTime          @default(now())
  fluxoId       String?
  // Quem submeteu p/ aprovação — notificado quando a aprovação é decidida.
  solicitadoPor String?
  aprovador     Usuario           @relation(fields: [aprovadorId], references: [id])
  fluxo         AprovacaoFluxo?   @relation(fields: [fluxoId], references: [id])
  necessidade   NecessidadeCompra? @relation(fields: [necessidadeId], references: [id], onDelete: Cascade)
  cotacao       CotacaoCompra?    @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
}

// Notificação in-app por usuário (toast estilo macOS + sino). Criada por eventos
// como aprovação de cotação (solicitada/aprovada/reprovada).
model Notificacao {
  id        String   @id @default(cuid())
  usuarioId String
  tipo      String   // ex.: COTACAO_APROVACAO_SOLICITADA, COTACAO_APROVADA, COTACAO_REPROVADA
  titulo    String
  mensagem  String
  link      String?
  lida      Boolean  @default(false)
  createdAt DateTime @default(now())
  usuario   Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, lida])
  @@index([usuarioId, createdAt])
}

model CentroCusto {
  id                     String                   @id @default(cuid())
  codigo                 String                   @unique
  nome                   String
  grupoCentroCustoId     String?
  ativo                  Boolean                  @default(true)
  // Centro de custo FABRIL (forno, extrusora, secador, vagonetas, esteiras) vs.
  // não-fabril (frota, escritório, vendas). Decide CIF×Despesa do consumo indireto.
  fabril                 Boolean                  @default(false)
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  grupoCentroCusto       GrupoCentroCusto?        @relation(fields: [grupoCentroCustoId], references: [id])
  necessidadesCompra     NecessidadeCompra[]
  requisicoesCompra      RequisicaoMaterial[]
  itensRequisicao        RequisicaoMaterialItem[]
  lancamentosFinanceiros LancamentoFinanceiro[]
  contasReceber          ContaReceber[]
  contasPagar            ContaPagar[]
  recorrencias           Recorrencia[]

  @@index([grupoCentroCustoId])
}

model Cliente {
  id                     String                 @id @default(cuid())
  tipoPessoa             TipoPessoa             @default(JURIDICA)
  razaoSocial            String
  nomeFantasia           String?
  cpfCnpj                String?                @unique
  ie                     String?
  email                  String?
  telefone               String?
  celular                String?
  status                 StatusCliente          @default(ATIVO)
  observacoes            String?
  cep                    String?
  logradouro             String?
  numero                 String?
  complemento            String?
  bairro                 String?
  cidade                 String?
  estado                 String?
  // Geolocalização (geomarketing). Preenchida por geocodificação (Nominatim/OSM)
  // ou ajuste manual (pino/URL do Google Maps). geoManual trava o automático.
  latitude               Float?
  longitude              Float?
  geoManual              Boolean                @default(false)
  geoReferencia          String?
  createdAt              DateTime               @default(now())
  updatedAt              DateTime               @updatedAt
  contasReceber          ContaReceber[]
  pedidosVenda           PedidoVenda[]          @relation("PedidoVendaCliente")
  pedidosVendaFinal      PedidoVenda[]          @relation("PedidoVendaClienteFinal")
  movimentacoesComodato  MovimentacaoComodato[]
  estoqueTerceiros       EstoqueItem[]          @relation("EstoqueTerceiros")
  movimentacoesTerceiros MovimentacaoEstoque[]  @relation("MovimentacoesTerceiros")
  recorrencias           Recorrencia[]
  contasContabeis        ContaContabil[]
  empresa                Empresa?

  @@index([cpfCnpj])
  @@index([status])
}

model Colaborador {
  id                         String               @id @default(cuid())
  nome                       String
  cpf                        String?              @unique
  // Matrícula na folha — casa a folha ao colaborador automaticamente (aprendida
  // no 1º vínculo, reusada nas próximas competências).
  matricula                  String?
  rg                         String?
  email                      String?
  telefone                   String?
  telegramChatId             String?
  cargo                      String?
  setorId                    String?
  // Classificação de custo para o fechamento da folha (rateio MOD/MOI/admin).
  classificacaoCusto         ClassificacaoCusto?
  // Vínculo: funcionário (folha de pagamento) ou prestador (lançamento de diaristas).
  tipoColaborador            TipoColaborador      @default(FUNCIONARIO)
  dataAdmissao               DateTime?
  dataDemissao               DateTime?
  usuarioId                  String?              @unique
  ativo                      Boolean              @default(true)
  // Áreas de operação (nomes das etapas do fluxo: Preparação, Conformação, …) em que
  // o colaborador pode atuar. Vazio = sem restrição (aparece como responsável em todas).
  areasOperacao              String[]             @default([])
  observacoes                String?
  createdAt                  DateTime             @default(now())
  updatedAt                  DateTime             @updatedAt
  etapasAprovacao            AprovacaoEtapa[]
  folhaItens                 FolhaItem[]
  diariaItens                DiariaItem[]
  ordensProducaoResponsavel  OrdemProducao[]      @relation("OrdemProducaoResponsavel")
  usuario                    Usuario?             @relation(fields: [usuarioId], references: [id])
  filiais                    Filial[]
  // Empresas em que o colaborador está presente — define onde ele aparece nos
  // lançamentos e onde a conta contábil dele (Salários a Pagar) é criada.
  empresas                   Empresa[]            @relation("ColaboradorEmpresas")
  contasContabeis            ContaContabil[]
  setor                      Setor?               @relation(fields: [setorId], references: [id])
  solicitacoesCompra         NecessidadeCompra[]
  requisicoesComoSolicitante RequisicaoMaterial[] @relation("RM_Solicitante")
  requisicoesComoAlmoxarife  RequisicaoMaterial[] @relation("RM_Almoxarife")
  inventarios                InventarioMaterial[]
}

// Classificação de custo do colaborador para o fechamento da folha:
// MOD → PEP-MOD; MOI → CIF a Apropriar; ADMIN → Despesa.
enum ClassificacaoCusto {
  MOD
  MOI
  ADMIN
}

// Vínculo do colaborador: FUNCIONARIO (CLT, vai p/ a folha de pagamento) ou
// PRESTADOR (diarista/terceiro, vai p/ o lançamento de diaristas).
enum TipoColaborador {
  FUNCIONARIO
  PRESTADOR
}

enum StatusFolha {
  EM_REVISAO
  FECHADA
  CANCELADA
}

// Folha de pagamento de uma competência: o PDF é subido, a IA extrai os itens, o
// usuário classifica (MOD/MOI/admin) e o fechamento apropria + gera Contas a Pagar.
model FolhaPagamento {
  id                String      @id @default(cuid())
  empresaId         String      @default("emp_tramontin")
  competencia       DateTime // 1º dia do mês de competência
  dataPagamento     DateTime?
  dataVencimento    DateTime?
  arquivoUrl        String?
  arquivoNome       String?
  status            StatusFolha @default(EM_REVISAO)
  totalBruto        Decimal     @default(0) @db.Decimal(15, 2)
  totalLiquido      Decimal     @default(0) @db.Decimal(15, 2)
  totalInssRetido   Decimal     @default(0) @db.Decimal(15, 2)
  totalInssPatronal Decimal     @default(0) @db.Decimal(15, 2)
  totalIrrf         Decimal     @default(0) @db.Decimal(15, 2)
  totalFgts         Decimal     @default(0) @db.Decimal(15, 2)
  lancamentoId      String? // lançamento de apropriação gerado no fechamento
  criadoPor         String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  empresa           Empresa     @relation(fields: [empresaId], references: [id])
  itens             FolhaItem[]

  @@unique([empresaId, competencia])
  @@index([empresaId, status])
}

model FolhaItem {
  id              String             @id @default(cuid())
  folhaId         String
  colaboradorId   String?
  matricula       String?
  nome            String
  cargo           String?
  classificacao   ClassificacaoCusto @default(ADMIN)
  bruto           Decimal            @default(0) @db.Decimal(15, 2)
  liquido         Decimal            @default(0) @db.Decimal(15, 2)
  inssRetido      Decimal            @default(0) @db.Decimal(15, 2)
  inssPatronal    Decimal            @default(0) @db.Decimal(15, 2)
  irrf            Decimal            @default(0) @db.Decimal(15, 2)
  fgts            Decimal            @default(0) @db.Decimal(15, 2)
  outrosDescontos Decimal            @default(0) @db.Decimal(15, 2)
  rubricas        Json? // detalhamento bruto da IA (proventos/descontos por código)
  folha           FolhaPagamento     @relation(fields: [folhaId], references: [id], onDelete: Cascade)
  colaborador     Colaborador?       @relation(fields: [colaboradorId], references: [id])

  @@index([folhaId])
  @@index([colaboradorId])
}

// ── Diárias (lançamento de diaristas) ───────────────────────────────────────
// Folha de diárias de um dia, organizada em blocos (grupos) por tipo/setor/turno,
// como o modelo de planilha em papel. Cada item é uma diária paga a um colaborador.
model DiariaFolha {
  id          String        @id @default(cuid())
  empresaId   String        @default("emp_tramontin")
  data        DateTime      @db.Date
  observacoes String?
  status      String        @default("ABERTA") // ABERTA | FECHADA
  total       Decimal       @default(0) @db.Decimal(15, 2)
  criadoPor   String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  empresa     Empresa       @relation(fields: [empresaId], references: [id])
  grupos      DiariaGrupo[]

  @@index([empresaId, data])
}

// Bloco da folha: um cabeçalho (tipo Fixos/Diversas · setor · turno Dia/Noite) com
// sua própria lista e subtotal — espelha cada quadro do modelo impresso.
model DiariaGrupo {
  id        String       @id @default(cuid())
  empresaId String       @default("emp_tramontin")
  folhaId   String
  tipo      String       @default("DIVERSAS") // FIXOS | DIVERSAS
  setor     String? // texto do bloco (ex.: "SETOR DE PRODUÇÃO", "DIVERSOS SETORES FABRICA")
  turno     String       @default("DIA") // DIA | NOITE
  ordem     Int          @default(0)
  folha     DiariaFolha  @relation(fields: [folhaId], references: [id], onDelete: Cascade)
  itens     DiariaItem[]

  @@index([folhaId])
}

model DiariaItem {
  id            String      @id @default(cuid())
  empresaId     String      @default("emp_tramontin")
  grupoId       String
  colaboradorId String
  servico       String? // descrição do serviço (ex.: "MOTORISTA 120/8*8")
  valor         Decimal     @default(0) @db.Decimal(15, 2)
  ordem         Int         @default(0)
  grupo         DiariaGrupo @relation(fields: [grupoId], references: [id], onDelete: Cascade)
  colaborador   Colaborador @relation(fields: [colaboradorId], references: [id])

  @@index([grupoId])
  @@index([colaboradorId])
}

model Setor {
  id                   String               @id @default(cuid())
  nome                 String
  descricao            String?
  ativo                Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  colaboradores        Colaborador[]
  solicitacoesCompra   NecessidadeCompra[]
  requisicoesMateriais RequisicaoMaterial[]
}

model CondicaoPagamento {
  id                String              @id @default(cuid())
  nome              String
  descricao         String?
  numeroParcelas    Int                 @default(1)
  prazoInicial      Int                 @default(0)
  intervaloParcelas Int                 @default(30)
  // Dias de vencimento de cada parcela a partir da emissão, ex.: "15,30,45" ou
  // irregular "30,45,90". Quando preenchido, define o nº e os prazos das parcelas
  // (sobrepõe numeroParcelas/prazoInicial/intervaloParcelas).
  diasParcelas      String?
  // Percentual de cada parcela sobre o total, ex.: "50,50" (entrada+saldo) ou
  // "50,30,20". Quando preenchido, cada parcela usa seu % (senão divide igual).
  percentuaisParcelas String?
  // "Faturado / a combinar": gera o título SEM data de vencimento prevista.
  semVencimento     Boolean             @default(false)
  descontoVista     Decimal?            @db.Decimal(5, 2)
  ativo             Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  pedidosVenda      PedidoVenda[]
  pedidosCompra     PedidoCompra[]      @relation("CondPgtoPedidoCompra")
  conferencias      ConferenciaCompra[] @relation("CondPgtoConferencia")
}

model ConferenciaCompra {
  id                   String                  @id @default(cuid())
  empresaId            String                  @default("emp_tramontin")
  numero               String
  pedidoId             String?                 @unique
  status               StatusConferenciaCompra @default(PENDENTE)
  condicaoPagamentoId  String?
  naturezaFinanceiraId String?
  dataConferencia      DateTime?
  responsavel          String?
  observacoes          String?
  // Campos Documento de Entrada (Nota Fiscal)
  tipoNota             String?                 @default("NORMAL")
  numeroNF             String?
  serie                String?
  dtEmissao            DateTime?
  ufOrigem             String?
  espDocumento         String?                 @default("SPED")
  fornecedorId         String?
  localEstoqueId       String?
  modoLocalEstoque     String?                 @default("POR_ITEM")
  // Financeiro
  frete                Decimal?                @db.Decimal(15, 2)
  tipoFrete            String?
  seguro               Decimal?                @db.Decimal(15, 2)
  despesas             Decimal?                @db.Decimal(15, 2)
  desconto             Decimal?                @db.Decimal(15, 2)
  vrTotal              Decimal?                @db.Decimal(15, 2)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  pedido               PedidoCompra?           @relation(fields: [pedidoId], references: [id])
  condicaoPagamentoRef CondicaoPagamento?      @relation("CondPgtoConferencia", fields: [condicaoPagamentoId], references: [id])
  naturezaFinanceira   NaturezaFinanceira?     @relation(fields: [naturezaFinanceiraId], references: [id])
  fornecedor           Fornecedor?             @relation(fields: [fornecedorId], references: [id])
  localEstoque         LocalEstoque?           @relation(fields: [localEstoqueId], references: [id])
  itens                ConferenciaCompraItem[]

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, numero])
  @@index([status])
  @@index([fornecedorId])
  @@index([empresaId])
}

model ConferenciaCompraItem {
  id                 String                @id @default(cuid())
  empresaId          String                @default("emp_tramontin")
  conferenciaId      String
  itemId             String
  // Unidade da COMPRA (herdada do pedido; null = base). quantidadeRecebida e
  // vlrUnitario ficam nesta unidade; conversão p/ base ao concluir.
  unidadeId          String?
  quantidadePedida   Decimal               @db.Decimal(15, 3)
  quantidadeRecebida Decimal               @default(0) @db.Decimal(15, 3)
  divergencia        Boolean               @default(false)
  observacao         String?
  // Campos NF item
  localEstoqueId     String?
  vlrUnitario        Decimal?              @db.Decimal(15, 2)
  vlrTotal           Decimal?              @db.Decimal(15, 2)
  vlrIPI             Decimal?              @db.Decimal(15, 2)
  vlrICMS            Decimal?              @db.Decimal(15, 2)
  tipoEntrada        String?
  codFiscal          String?
  tpOper             String?
  desconto           Decimal?              @db.Decimal(15, 4)
  conferencia        ConferenciaCompra     @relation(fields: [conferenciaId], references: [id], onDelete: Cascade)
  item               Item                  @relation(fields: [itemId], references: [id])
  localEstoque       LocalEstoque?         @relation(fields: [localEstoqueId], references: [id])
  movimentacoes      MovimentacaoEstoque[]
  empresa            Empresa               @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
}

model Configuracao {
  chave     String   @id
  valor     String?
  updatedAt DateTime @updatedAt
}

// Integração de pagamento (maquininha) POR EMPRESA. Cada CNPJ do grupo tem a
// própria conta na adquirente. Hoje só a Stone tem API de nuvem para cobrança
// automática; Sicredi/Caixa seguem manuais no Caixa. accessToken é secret
// (nunca volta no GET — mascarado). ativo liga a cobrança automática no Caixa.
model IntegracaoPagamento {
  id           String   @id @default(cuid())
  empresaId    String
  provedor     String   @default("STONE") // STONE (futuro: outras adquirentes)
  ambiente     String   @default("PRODUCAO") // PRODUCAO | SANDBOX
  accessToken  String? // secret — credencial da adquirente
  pontoVendaId String? // ID do ponto de venda / serial do terminal
  ativo        Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  empresa      Empresa  @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, provedor])
  @@index([empresaId])
}

model ContaPagar {
  id                    String                 @id @default(cuid())
  empresaId             String                 @default("emp_tramontin")
  numero                String
  fornecedorId          String?
  // Beneficiário polimórfico do lançamento de SAÍDA: 'FORNECEDOR' | 'COLABORADOR'
  // | null (encargo sem vínculo, ex.: INSS patronal/FGTS). Não interfere na
  // contabilização — quem define as contas é a natureza financeira.
  beneficiarioTipo      String?
  beneficiarioId        String?
  descricao             String
  categoria             String?
  centroCustoId         String?
  contaBancariaId       String?
  grupoParcelamentoId   String?
  recorrenciaId         String?
  pedidoCompraId        String?
  parcelaNumero         Int?
  parcelaTotal          Int?
  valorOriginal         Decimal                @db.Decimal(15, 2)
  valorPago             Decimal                @default(0) @db.Decimal(15, 2)
  valorMulta            Decimal                @default(0) @db.Decimal(15, 2)
  valorJuros            Decimal                @default(0) @db.Decimal(15, 2)
  dataVencimento        DateTime? // null = sem data prevista (ex.: "Faturado")
  dataPagamento         DateTime?
  dataCompetencia       DateTime?
  status                StatusConta            @default(ABERTA)
  formaPagamento        String?
  notaFiscal            String?
  intragrupo            Boolean                @default(false)
  // Folha de pagamento: quando true, a provisão já foi feita pela apropriação da
  // folha — a contabilização do título posta SÓ a liquidação (D passivo / C banco).
  semProvisao           Boolean                @default(false)
  folhaId               String?
  // Conta de passivo a debitar na liquidação (folha: INSS/IRRF/FGTS a Recolher).
  // Quando null, o passivo vem do colaborador/natureza (comportamento padrão).
  contaPassivoId        String?
  contaReceberEspelhoId String?                @unique
  observacoes           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  fornecedor            Fornecedor?            @relation(fields: [fornecedorId], references: [id])
  centroCusto           CentroCusto?           @relation(fields: [centroCustoId], references: [id])
  contaBancaria         ContaBancaria?         @relation(fields: [contaBancariaId], references: [id])
  recorrencia           Recorrencia?           @relation(fields: [recorrenciaId], references: [id])
  contaReceberEspelho   ContaReceber?          @relation("EspelhoIntragrupoCR", fields: [contaReceberEspelhoId], references: [id])
  pedidoCompra          PedidoCompra?          @relation(fields: [pedidoCompraId], references: [id])
  naturezaFinanceiraId  String?
  naturezaFinanceira    NaturezaFinanceira?    @relation(fields: [naturezaFinanceiraId], references: [id])
  lancamentos           LancamentoFinanceiro[]
  naturezas             ContaPagarNatureza[]   // rateio gerencial por natureza (definido na baixa)

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, numero])
  @@index([dataVencimento])
  @@index([fornecedorId])
  @@index([status])
  @@index([grupoParcelamentoId])
  @@index([recorrenciaId])
  @@index([empresaId])
}

// Rateio gerencial de um título a pagar por natureza financeira (definido na baixa).
// Como classificação (dimensão) nas partidas — não cria títulos separados. PCs de
// estoque já têm o custo no estoque; aqui a natureza é só etiqueta gerencial. Em
// títulos avulsos, a contabilização divide a despesa entre as naturezas.
model ContaPagarNatureza {
  id                   String             @id @default(cuid())
  contaPagarId         String
  naturezaFinanceiraId String
  detalhamento         String?
  valor                Decimal            @db.Decimal(15, 2)
  createdAt            DateTime           @default(now())

  contaPagar           ContaPagar         @relation(fields: [contaPagarId], references: [id], onDelete: Cascade)
  naturezaFinanceira   NaturezaFinanceira @relation(fields: [naturezaFinanceiraId], references: [id])

  @@index([contaPagarId])
  @@index([naturezaFinanceiraId])
}

model ContaReceber {
  id                    String                 @id @default(cuid())
  empresaId             String                 @default("emp_tramontin")
  numero                String
  clienteId             String?
  pedidoVendaId         String?
  // Beneficiário polimórfico da ENTRADA: 'CLIENTE' | null (receita sem vínculo,
  // ex.: rendimento de aplicação, devolução de imposto). Não interfere na
  // contabilização — quem define as contas é a natureza financeira.
  beneficiarioTipo      String?
  beneficiarioId        String?
  descricao             String
  centroCustoId         String?
  contaBancariaId       String?
  grupoParcelamentoId   String?
  recorrenciaId         String?
  parcelaNumero         Int?
  parcelaTotal          Int?
  valorOriginal         Decimal                @db.Decimal(15, 2)
  valorPago             Decimal                @default(0) @db.Decimal(15, 2)
  valorMulta            Decimal                @default(0) @db.Decimal(15, 2)
  valorJuros            Decimal                @default(0) @db.Decimal(15, 2)
  dataVencimento        DateTime? // null = sem data prevista (ex.: "Faturado")
  dataPagamento         DateTime?
  dataCompetencia       DateTime?
  status                StatusConta            @default(ABERTA)
  formaPagamento        String?
  nossoNumero           String?
  intragrupo            Boolean                @default(false)
  observacoes           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  cliente               Cliente?               @relation(fields: [clienteId], references: [id])
  pedidoVenda           PedidoVenda?           @relation(fields: [pedidoVendaId], references: [id])
  centroCusto           CentroCusto?           @relation(fields: [centroCustoId], references: [id])
  contaBancaria         ContaBancaria?         @relation(fields: [contaBancariaId], references: [id])
  recorrencia           Recorrencia?           @relation(fields: [recorrenciaId], references: [id])
  naturezaFinanceiraId  String?
  naturezaFinanceira    NaturezaFinanceira?    @relation(fields: [naturezaFinanceiraId], references: [id])
  espelhoPagar          ContaPagar?            @relation("EspelhoIntragrupoCR")
  lancamentos           LancamentoFinanceiro[]

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, numero])
  @@index([clienteId])
  @@index([dataVencimento])
  @@index([status])
  @@index([recorrenciaId])
  @@index([grupoParcelamentoId])
  @@index([empresaId])
}

model Banco {
  id        String          @id @default(cuid())
  codigo    String?         @unique
  nome      String
  ativo     Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  contas    ContaBancaria[]
}

model ContaBancaria {
  id               String                 @id @default(cuid())
  empresaId        String                 @default("emp_tramontin")
  nome             String
  bancoId          String?
  agencia          String?
  numero           String?
  tipo             TipoContaBancaria      @default(CORRENTE)
  saldoInicial     Decimal                @default(0) @db.Decimal(15, 2)
  ativo            Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  banco            Banco?                 @relation(fields: [bancoId], references: [id])
  lancamentos      LancamentoFinanceiro[]
  pedidoPagamentos PedidoVendaPagamento[]
  contasReceber    ContaReceber[]
  contasPagar      ContaPagar[]
  recorrencias     Recorrencia[]
  importacoesOFX   ImportacaoOFX[]
  contasContabeis  ContaContabil[]

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@index([bancoId])
  @@index([empresaId])
}

// Natureza financeira (estrutura de fluxo de caixa / DRE): classifica os títulos
// e lançamentos por tipo (entrada/saída) e grupo. É a única classificação
// gerencial — o plano de contas contábil vive em ContaContabil. Subgrupo é um
// nível opcional de organização dentro do grupo.
model NaturezaSubgrupo {
  id        String               @id @default(cuid())
  empresaId String               @default("emp_tramontin")
  nome      String
  grupo     NaturezaGrupo
  ativo     Boolean              @default(true)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  naturezas NaturezaFinanceira[]
  empresa   Empresa              @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
}

model NaturezaFinanceira {
  id            String              @id @default(cuid())
  empresaId     String              @default("emp_tramontin")
  nome          String
  tipo          NaturezaTipo
  grupo         NaturezaGrupo
  subgrupoId    String?
  ativo         Boolean             @default(true)
  // Natureza de Custo Indireto de Fabricação: o débito de origem vai para
  // "CIF a Apropriar" (1.1.4.0001), não para a conta de resultado da natureza.
  cif           Boolean             @default(false)
  // Destino contábil que ESTA natureza implica — usado só para o alerta de coerência
  // na requisição (compara com o destino real das flags do item). Não roteia nada.
  destinoSugerido DestinoConsumo?
  // Aparece no seletor da Requisição de Material (consumo de estoque). Naturezas de
  // tesouraria/compra/investimento ficam false e não poluem a RM. Não apaga nada.
  aplicavelRequisicao Boolean         @default(false)
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  subgrupo      NaturezaSubgrupo?   @relation(fields: [subgrupoId], references: [id])
  empresa       Empresa             @relation(fields: [empresaId], references: [id])
  contasReceber ContaReceber[]
  contasPagar   ContaPagar[]
  pedidosVenda  PedidoVenda[]
  conferencias  ConferenciaCompra[]
  lancamentos   LancamentoFinanceiro[]
  recorrencias  Recorrencia[]
  requisicoes   RequisicaoMaterial[] // natureza da saída de estoque (ex.: CIF)
  requisicaoItens RequisicaoMaterialItem[] // natureza por item da requisição
  contasPagarRateio ContaPagarNatureza[] // rateio gerencial por natureza na baixa de contas a pagar
  itensPadrao   Item[]              @relation("ItemNaturezaPadrao") // natureza-padrão do item
  partidasContabeis PartidaContabil[] // dimensão natureza nas partidas (ex.: CIF)
  // Conta de RESULTADO (receita p/ ENTRADA, despesa p/ SAIDA): vínculo via
  // ContaContabil.naturezaFinanceiraId (uma conta por natureza).
  contasContabeis ContaContabil[]    @relation("NaturezaResultado")
  // Conta de CONTRAPARTIDA patrimonial: ATIVO (a receber) p/ ENTRADA, PASSIVO
  // (a pagar/obrigação) p/ SAIDA. Debitada/creditada na provisão e revertida na
  // liquidação — assim a saída/entrada passa pelo ativo/passivo, não direto no
  // resultado. Definida no cadastro da natureza.
  contaContrapartidaId String?
  contaContrapartida   ContaContabil? @relation("NaturezaContrapartida", fields: [contaContrapartidaId], references: [id])

  @@index([empresaId])
  @@index([tipo])
  @@index([subgrupoId])
}

// Plano de contas CONTÁBIL (módulo Contabilidade). Diferente das Naturezas
// Financeiras (classificação gerencial), aqui cada conta tem natureza
// devedora/credora, grupo (Ativo/Passivo/PL/Resultado) e hierarquia
// sintética × analítica. Clientes e fornecedores ganham uma conta analítica
// própria (clienteId/fornecedorId); estoque fica só sintético.
enum GrupoContabil {
  ATIVO
  PASSIVO
  PATRIMONIO_LIQUIDO
  RESULTADO
}

enum NaturezaContabil {
  DEVEDORA
  CREDORA
}

enum TipoContaContabil {
  SINTETICA
  ANALITICA
}

model ContaContabil {
  id               String            @id @default(cuid())
  empresaId        String            @default("emp_tramontin")
  codigo           String // hierárquico, ex "1.1.02.0001"
  nome             String
  grupo            GrupoContabil
  natureza         NaturezaContabil
  tipo             TipoContaContabil
  nivel            Int
  aceitaLancamento Boolean           @default(false) // true só nas analíticas
  paiId            String?
  clienteId        String? // analítica vinculada a um cliente (uma por empresa)
  fornecedorId     String? // analítica vinculada a um fornecedor (uma por empresa)
  colaboradorId    String? // analítica vinculada a um colaborador (Salários a Pagar, uma por empresa)
  naturezaFinanceiraId String? // analítica de resultado vinculada a uma natureza
  localEstoqueId   String? // analítica de estoque vinculada a um local
  contaBancariaId  String? // analítica de disponibilidade vinculada a uma conta bancária
  dreSecaoId       String? // seção da DRE (estrutura gerencial editável) — só contas de resultado
  ordemDre         Int               @default(0) // ordem da conta dentro da seção da DRE
  ativo            Boolean           @default(true)
  manual           Boolean           @default(false) // true = criada manualmente pelo usuário; false = automática (seed/motor)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  pai              ContaContabil?    @relation("ContaArvore", fields: [paiId], references: [id])
  filhos           ContaContabil[]   @relation("ContaArvore")
  cliente          Cliente?          @relation(fields: [clienteId], references: [id])
  fornecedor       Fornecedor?       @relation(fields: [fornecedorId], references: [id])
  colaborador      Colaborador?      @relation(fields: [colaboradorId], references: [id])
  naturezaFinanceira NaturezaFinanceira? @relation("NaturezaResultado", fields: [naturezaFinanceiraId], references: [id])
  contrapartidaDeNaturezas NaturezaFinanceira[] @relation("NaturezaContrapartida")
  localEstoque     LocalEstoque?     @relation(fields: [localEstoqueId], references: [id])
  contaBancaria    ContaBancaria?    @relation(fields: [contaBancariaId], references: [id])
  empresa          Empresa           @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, codigo])
  // Unicidade por PAI: um cliente tem várias analíticas com o mesmo clienteId —
  // Clientes a Receber (1.1.2.x) e Bens a Entregar (1.1.4.x), ambas ATIVO, e
  // Material a Entregar (2.1.2.x), PASSIVO. Uma por conta-pai.
  @@unique([empresaId, paiId, clienteId])
  @@unique([empresaId, fornecedorId])
  @@unique([empresaId, colaboradorId])
  @@unique([empresaId, naturezaFinanceiraId])
  @@unique([empresaId, localEstoqueId])
  @@unique([empresaId, contaBancariaId])
  @@index([empresaId])
  @@index([paiId])
  @@index([grupo])
  partidas PartidaContabil[]
}

// Lançamentos contábeis (partidas dobradas). Derivados dos fatos do ERP
// (vendas, compras, recebimentos, pagamentos…) — débito = crédito por lançamento.
enum OrigemLancamento {
  VENDA // título a receber gerado (D Clientes / C Receita)
  RECEBIMENTO // baixa de a receber (D Caixa / C Clientes)
  COMPRA // título a pagar gerado (D Despesa / C Fornecedores)
  PAGAMENTO // baixa de a pagar (D Fornecedores / C Caixa)
  ESTOQUE_ENTRADA // entrada de compra (D Estoque / C Fornecedor)
  ESTOQUE_SAIDA // CMV na venda (D Custos / C Estoque)
  ESTOQUE_PRODUCAO // entrada de produção (D Estoque / C Custo de Produção)
  ESTOQUE_CONSUMO // requisição/consumo (D Consumo de Materiais / C Estoque)
  ESTOQUE_AJUSTE // ajuste/inventário (sobra: C Sobras; perda: D Perdas)
  ESTOQUE_TRANSFERENCIA // transferência entre locais (D destino / C origem)
  DEPRECIACAO // depreciação do imobilizado (D Despesa / C Depreciação Acumulada)
  ENCERRAMENTO // encerramento do exercício (zera Resultado contra o PL)
  RECEITA_ENTREGA // reconhecimento de receita na entrega (D Material a Entregar / C Receita)
  FOLHA_PAGAMENTO // apropriação da folha (D PEP-MOD/CIF/Despesa / C Salários, INSS, IRRF, FGTS)
  MANUAL
  ESTORNO
}

enum TipoPartida {
  DEBITO
  CREDITO
}

model LancamentoContabil {
  id          String              @id @default(cuid())
  empresaId   String              @default("emp_tramontin")
  numero      String? // código sequencial do lançamento (ex.: LC-2026-0001) p/ identificação no razão
  data        DateTime // competência
  historico   String
  origemTipo  OrigemLancamento
  origemId    String? // id do fato gerador (ContaReceber, ContaPagar…)
  criadoPor   String? // usuário responsável (lançamentos manuais)
  estornoDeId String?             @unique
  estornoDe   LancamentoContabil? @relation("Estorno", fields: [estornoDeId], references: [id])
  estorno     LancamentoContabil? @relation("Estorno")
  partidas    PartidaContabil[]
  createdAt   DateTime            @default(now())
  empresa     Empresa             @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, origemTipo, origemId])
  @@unique([empresaId, numero])
  @@index([empresaId, data])
}

model PartidaContabil {
  id           String             @id @default(cuid())
  empresaId    String             @default("emp_tramontin")
  lancamentoId String
  contaId      String
  tipo         TipoPartida
  valor        Decimal            @db.Decimal(15, 2)
  clienteId    String? // razão auxiliar
  fornecedorId String? // razão auxiliar
  // Dimensões de custeio (não são contas): estágio do WIP e natureza (ex.: CIF).
  estagio              EstadoWIP?
  naturezaFinanceiraId String?
  lancamento   LancamentoContabil @relation(fields: [lancamentoId], references: [id], onDelete: Cascade)
  conta        ContaContabil      @relation(fields: [contaId], references: [id])
  empresa      Empresa            @relation(fields: [empresaId], references: [id])
  naturezaFinanceira NaturezaFinanceira? @relation(fields: [naturezaFinanceiraId], references: [id])

  @@index([empresaId])
  @@index([contaId])
  @@index([lancamentoId])
  @@index([naturezaFinanceiraId])
  @@index([estagio])
}

enum StatusFechamento {
  FECHADO
  REABERTO
}

enum DREOperacao {
  SOMA
  SUBTRAI
  SUBTOTAL // linha "=" — resultado acumulado até o ponto (ex.: Receita Líquida, EBITDA)
}

// Seção da DRE gerencial (estrutura editável por empresa): agrupa contas de
// resultado e define se o subtotal soma ou subtrai no resultado final.
model DRESecao {
  id        String      @id @default(cuid())
  empresaId String      @default("emp_tramontin")
  nome      String
  operacao  DREOperacao @default(SOMA)
  ordem     Int         @default(0)
  createdAt DateTime    @default(now())

  @@index([empresaId])
}

// Encerramento do exercício: zera o grupo Resultado contra o PL e trava
// lançamentos datados dentro do exercício fechado. Reabertura só do último.
model FechamentoContabil {
  id           String           @id @default(cuid())
  empresaId    String           @default("emp_tramontin")
  exercicio    Int // ano (ex.: 2026)
  dataInicio   DateTime // 1º jan do exercício
  dataFim      DateTime // 31 dez 23:59:59
  resultado    Decimal          @db.Decimal(15, 2) // lucro(+)/prejuízo(−) apurado
  lancamentoId String? // lançamento de encerramento
  status       StatusFechamento @default(FECHADO)
  reabertoEm   DateTime?
  createdAt    DateTime         @default(now())

  @@unique([empresaId, exercicio])
  @@index([empresaId])
}

enum MetodoDepreciacao {
  LINEAR
}

enum StatusImobilizado {
  ATIVO
  BAIXADO
}

// Bem do ativo não circulante (imobilizado). Ligado ao plano de contas: o bem tem
// sua própria analítica sob 1.2.1; a depreciação acumulada (1.2.2) e a despesa de
// depreciação (3.3.9003) são contas compartilhadas. Sem FK no banco (padrão do
// projeto) — as contas são referenciadas por id em campos String.
model Imobilizado {
  id                          String                  @id @default(cuid())
  empresaId                   String                  @default("emp_tramontin")
  descricao                   String
  dataAquisicao               DateTime
  valorAquisicao              Decimal                 @db.Decimal(15, 2)
  valorResidual               Decimal                 @default(0) @db.Decimal(15, 2)
  vidaUtilMeses               Int
  deprecia                    Boolean                 @default(true) // terrenos e bens não depreciáveis = false
  metodo                      MetodoDepreciacao       @default(LINEAR)
  status                      StatusImobilizado       @default(ATIVO)
  contaAtivoId                String? // analítica do bem (1.2.1.NNNN)
  contaDepreciacaoAcumuladaId String? // 1.2.2 (compartilhada)
  contaDespesaId              String? // 3.3.9003 (compartilhada)
  observacoes                 String?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  depreciacoes                DepreciacaoLancamento[]

  @@index([empresaId])
}

// Registro de depreciação mensal de um bem (idempotente por competência).
model DepreciacaoLancamento {
  id                   String      @id @default(cuid())
  empresaId            String      @default("emp_tramontin")
  imobilizadoId        String
  competencia          DateTime // 1º dia do mês de competência
  valor                Decimal     @db.Decimal(15, 2)
  lancamentoContabilId String? // lançamento contábil gerado
  createdAt            DateTime    @default(now())
  imobilizado          Imobilizado @relation(fields: [imobilizadoId], references: [id], onDelete: Cascade)

  @@unique([imobilizadoId, competencia])
  @@index([empresaId])
}

model Recorrencia {
  id                    String                   @id @default(cuid())
  empresaId             String                   @default("emp_tramontin")
  tipo                  TipoRecorrencia
  descricao             String
  valor                 Decimal                  @db.Decimal(15, 2)
  naturezaFinanceiraId  String?
  contaBancariaId       String?
  clienteId             String?
  fornecedorId          String?
  centroCustoId         String?
  periodicidade         PeriodicidadeRecorrencia @default(MENSAL)
  diaVencimento         Int                      @default(1)
  proximaGeracao        DateTime
  ativo                 Boolean                  @default(true)
  observacoes           String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  naturezaFinanceira    NaturezaFinanceira?      @relation(fields: [naturezaFinanceiraId], references: [id])
  contaBancaria         ContaBancaria?           @relation(fields: [contaBancariaId], references: [id])
  cliente               Cliente?                 @relation(fields: [clienteId], references: [id])
  fornecedor            Fornecedor?              @relation(fields: [fornecedorId], references: [id])
  centroCusto           CentroCusto?             @relation(fields: [centroCustoId], references: [id])
  contasReceber         ContaReceber[]
  contasPagar           ContaPagar[]

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@index([ativo])
  @@index([proximaGeracao])
  @@index([empresaId])
}

model CotacaoCompra {
  id                   String              @id @default(cuid())
  empresaId            String              @default("emp_tramontin")
  numero               String
  necessidadeId        String?
  status               StatusCotacaoCompra @default(PENDENTE)
  dataLimiteResposta   DateTime?
  observacoes          String?
  aprovadoPor          String?
  dataAprovacao        DateTime?
  fornecedorVencedorId String?
  motivoReprovacao     String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  infoEntrega          String?
  nome                 String?
  necessidade          NecessidadeCompra?  @relation(fields: [necessidadeId], references: [id])
  fornecedores         CotacaoFornecedor[]
  pedidos              PedidoCompra[]
  aprovacoes           AprovacaoSC[]

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, numero])
  @@index([status])
  @@index([empresaId])
}

model CotacaoFornecedor {
  id                     String                       @id @default(cuid())
  cotacaoId              String
  fornecedorId           String
  status                 StatusRespostaFornecedor     @default(AGUARDANDO)
  prazoEntregaDias       Int?
  condicoesPagamento     String?
  observacao             String?
  totalCalculado         Decimal?                     @db.Decimal(15, 2)
  melhorOpcao            Boolean                      @default(false)
  createdAt              DateTime                     @default(now())
  updatedAt              DateTime                     @updatedAt
  desconto               Decimal?                     @db.Decimal(5, 2)
  despesas               Decimal?                     @db.Decimal(15, 2)
  frete                  Decimal?                     @db.Decimal(15, 2)
  seguro                 Decimal?                     @db.Decimal(15, 2)
  tipoFrete              String?
  vrDesconto             Decimal?                     @db.Decimal(15, 2)
  AnexoCotacaoFornecedor AnexoCotacaoFornecedor[]
  cotacao                CotacaoCompra                @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  fornecedor             Fornecedor                   @relation(fields: [fornecedorId], references: [id])
  historico              CotacaoFornecedorHistorico[]
  itens                  CotacaoFornecedorItem[]

  @@unique([cotacaoId, fornecedorId])
}

model CotacaoFornecedorHistorico {
  id                  String            @id @default(cuid())
  cotacaoFornecedorId String
  versao              Int               @default(1)
  totalCalculado      Decimal?          @db.Decimal(15, 2)
  frete               Decimal?          @db.Decimal(15, 2)
  tipoFrete           String?
  desconto            Decimal?          @db.Decimal(5, 2)
  vrDesconto          Decimal?          @db.Decimal(15, 2)
  despesas            Decimal?          @db.Decimal(15, 2)
  seguro              Decimal?          @db.Decimal(15, 2)
  condicoesPagamento  String?
  prazoEntregaDias    Int?
  observacao          String?
  itensSnapshot       Json?
  createdAt           DateTime          @default(now())
  cotacaoFornecedor   CotacaoFornecedor @relation(fields: [cotacaoFornecedorId], references: [id], onDelete: Cascade)

  @@index([cotacaoFornecedorId])
}

model CotacaoFornecedorItem {
  id                  String            @id @default(cuid())
  cotacaoFornecedorId String
  itemId              String
  quantidade          Decimal           @db.Decimal(15, 3)
  precoUnitario       Decimal?          @db.Decimal(15, 2)
  subtotal            Decimal?          @db.Decimal(15, 2)
  disponivel          Boolean           @default(true)
  qtdDisponivel       Decimal?          @db.Decimal(15, 3)
  situacao            String?           @default("CONSIDERA")
  desconto            Decimal?          @db.Decimal(15, 4)
  cotacaoFornecedor   CotacaoFornecedor @relation(fields: [cotacaoFornecedorId], references: [id], onDelete: Cascade)
  item                Item              @relation(fields: [itemId], references: [id])
}

model Empresa {
  id                        String                  @id @default(cuid())
  razaoSocial               String
  nomeFantasia              String?
  cnpj                      String                  @unique
  ie                        String?
  im                        String?
  email                     String?
  telefone                  String?
  cep                       String?
  logradouro                String?
  numero                    String?
  complemento               String?
  bairro                    String?
  cidade                    String?
  estado                    String?
  // ── multiempresa: a Empresa é o tenant do grupo ────────────────────────────
  slug                      String?                 @unique
  ativo                     Boolean                 @default(true)
  // Fábrica/indústria: se true, a baixa de produto acabado na venda vira CPV;
  // se false (só revenda, ex.: Cimento e Mix), toda baixa vira CMV.
  industrializa             Boolean                 @default(false)
  // vínculo intragrupo (Fase 4): a empresa como cliente/fornecedor das irmãs
  clienteId                 String?                 @unique
  fornecedorId              String?                 @unique
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  cliente                   Cliente?                @relation(fields: [clienteId], references: [id])
  fornecedor                Fornecedor?             @relation(fields: [fornecedorId], references: [id])
  colaboradores             Colaborador[]           @relation("ColaboradorEmpresas")
  conferenciaCompras        ConferenciaCompra[]
  conferenciaCompraItems    ConferenciaCompraItem[]
  contaPagars               ContaPagar[]
  contaRecebers             ContaReceber[]
  folhasPagamento           FolhaPagamento[]
  diariaFolhas              DiariaFolha[]
  naturezasFinanceiras      NaturezaFinanceira[]
  naturezaSubgrupos         NaturezaSubgrupo[]
  contaBancarias            ContaBancaria[]
  recorrencias              Recorrencia[]
  cotacaoCompras            CotacaoCompra[]
  estoqueItems              EstoqueItem[]
  itemCustos                ItemCustoEmpresa[]
  tabelasPreco              TabelaPreco[]

  contasPagar          ContaPagar[]
  cotacao              CotacaoCompra?         @relation(fields: [cotacaoId], references: [id])
  necessidade          NecessidadeCompra?     @relation(fields: [necessidadeId], references: [id])
  condicaoPagamentoRef CondicaoPagamento?     @relation("CondPgtoPedidoCompra", fields: [condicaoPagamentoId], references: [id])
  fornecedor           Fornecedor             @relation(fields: [fornecedorId], references: [id])
  pedidoVendaEspelho   PedidoVenda?           @relation("EspelhoIntragrupo", fields: [pedidoVendaEspelhoId], references: [id])
  itens                PedidoCompraItem[]

  empresa       Empresa @relation(fields: [empresaId], references: [id])
  criadoPor     String? // autoria: carimbado automaticamente pelo proxy de sessão
  atualizadoPor String? // autoria: última edição manual (proxy de sessão)

  @@unique([empresaId, numero])
  @@index([fornecedorId])
  @@index([status])
  @@index([necessidadeId])
  @@index([empresaId])
}

model PedidoCompraItem {
  id            String        @id @default(cuid())
  pedidoId      String
  itemId        String
  // Unidade da COMPRA (null = unidade base do item). quantidade/precoUnitario
  // ficam nesta unidade; a conversão p/ base (× / ÷ fatorConversao do ItemUnidade)
  // é aplicada ao dar entrada (concluir conferência).
  unidadeId     String?
  quantidade    Decimal       @db.Decimal(15, 3)
  precoUnitario Decimal       @db.Decimal(15, 2)
  valorTotal    Decimal       @db.Decimal(15, 2)
  situacao      String?       @default("CONSIDERA")
  desconto      Decimal?      @db.Decimal(15, 4)
  // Centro de custo é HERANÇA/ORÇAMENTO, não classificação de custo. Serve para o
  // controle de compromisso orçamentário por centro na compra e para pré-preencher
  // a entrada e a RM. NÃO decide CIF×Despesa×Imobilizado — isso continua na
  // precedência do material (compoe_custo → capitaliza → centro) na entrada/RM.
  // O pedido propõe; o destino de custo é decidido no material.
  centroCustoId String?
  centroCusto   CentroCusto?  @relation(fields: [centroCustoId], references: [id])
  // TES da linha (comportamento/operação) + compoeCusto preenchido pelo TES
  // (null = herda item). Herdam para a entrada; NÃO decidem destino de custo.
  tesId         String?
  tes           TipoOperacao? @relation(fields: [tesId], references: [id])
  compoeCusto   Boolean?
  item          Item          @relation(fields: [itemId], references: [id])
  pedido        PedidoCompra  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)

  @@index([centroCustoId])
}

model PedidoVenda {
  id                      String                 @id @default(cuid())
  empresaId               String                 @default("emp_tramontin")
  numero                  String
  numeroOrcamento         String?
  intragrupo              Boolean                @default(false)
  clienteId               String
  // Venda à ordem: nas entregas (matriz) o `cliente` é o adquirente (empresa
  // intermediária) e o destinatário (cliente final) fica aqui. null = normal.
  clienteFinalId          String?
  tabelaPrecoId           String?
  vendedorId              String?
  modalidade              String                 @default("AGENDADA") // legado/derivado de necessidadeEntrega (RETIRADA→BALCAO, ENTREGA→AGENDADA); mantido p/ relatórios
  // Duas necessidades escolhidas na criação (substituem a escolha de modalidade):
  necessidadePagamento    String                 @default("A_PRAZO") // A_VISTA (recebe agora) | A_PRAZO (conta a receber futura)
  necessidadeEntrega      String                 @default("ENTREGA") // RETIRADA (leva na hora) | ENTREGA (agendada via minutas)
  status                  StatusPedidoVenda      @default(ORCAMENTO)
  // Duas dimensões independentes do pedido (derivadas, mas persistidas p/ filtro):
  //  • entrega   → minutas (Pendente/Parcial/Entregue)
  //  • financeiro→ contas a receber, guiado pela condição de pagamento
  statusEntrega           StatusEntregaPedido    @default(PENDENTE)
  statusFinanceiro        StatusFinanceiroPedido @default(NAO_FATURADO)
  dataEmissao             DateTime               @default(now())
  dataEntrega             DateTime?
  dataConclusao           DateTime?
  // Venda à ordem (triangular): estoque sai de OUTRA empresa do grupo. null =
  // normal (estoque da própria empresa). precoTransferencia é informativo na v1.
  estoqueOrigemEmpresaId  String?
  precoTransferencia      Decimal?               @db.Decimal(15, 2)
  // Pedido de ENTREGA gerado na empresa de origem aponta de volta p/ a venda
  // comercial (triangular). null = pedido comum ou a própria venda comercial.
  pedidoVendaOrigemId     String?
  valorProdutos           Decimal                @default(0) @db.Decimal(15, 2)
  valorDesconto           Decimal                @default(0) @db.Decimal(15, 2)
  valorFrete              Decimal                @default(0) @db.Decimal(15, 2)
  valorTotal              Decimal                @default(0) @db.Decimal(15, 2)
  condicaoPagamento       String?
  condicaoPagamentoId     String?
  naturezaFinanceiraId    String?
  formaPagamento          String?
  observacoes             String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt
  contasReceber           ContaReceber[]
  espelhoCompra           PedidoCompra?          @relation("EspelhoIntragrupo")
  cliente                 Cliente                @relation("PedidoVendaCliente", fields: [clienteId], references: [id])
  clienteFinal            Cliente?               @relation("PedidoVendaClienteFinal", fields: [clienteFinalId], references: [id])
  condicaoPagamentoRef    CondicaoPagamento?     @relation(fields: [condicaoPagamentoId], references: [id])
  naturezaFinanceira      NaturezaFinanceira?    @relation(fields: [naturezaFinanceiraId], references: [id])
  tabelaPreco             TabelaPreco?           @relation(fields: [tabelaPrecoId], references: [id])
  vendedor                Vendedor?              @relation(fields: [vendedorId], references: [id])
  itens                   PedidoVendaItem[]
  pagamentos              PedidoVendaPagamento[]
  minutas                 Minuta[]
  movimentacoesVendaOrdem MovimentacaoEstoque[]  @relation("MovimentacoesVendaOrdem")
  leads                   Lead[]

  empresa              Empresa       @relation("PedidoVendaEmpresa", fields: [empresaId], references: [id])
  estoqueOrigemEmpresa Empresa?      @relation("PedidoVendaEstoqueOrigem", fields: [estoqueOrigemEmpresaId], references: [id])
  pedidoVendaOrigem    PedidoVenda?  @relation("EntregaTriangular", fields: [pedidoVendaOrigemId], references: [id])
  entregasTriangular   PedidoVenda[] @relation("EntregaTriangular")
  criadoPor            String? // autoria: carimbado automaticamente pelo proxy de sessão
  atualizadoPor        String? // autoria: última edição manual (proxy de sessão)

  @@unique([empresaId, numero])
  @@index([clienteId])
  @@index([clienteFinalId])
  @@index([dataEmissao])
  @@index([status])
  @@index([vendedorId])
  @@index([empresaId])
  @@index([estoqueOrigemEmpresaId])
}

// Formas de pagamento previstas do pedido (pagamento misto: PIX + dinheiro
// etc.). O Caixa pré-carrega esses valores; PedidoVenda.formaPagamento guarda
// o resumo em texto ("PIX + Dinheiro") para as exibições/impressões.
model PedidoVendaPagamento {
  id              String         @id @default(cuid())
  pedidoVendaId   String
  forma           String
  valor           Decimal        @db.Decimal(15, 2)
  ordem           Int            @default(0)
  contaBancariaId String? // conta de destino do recebimento (preenchida ao receber no caixa)
  pedidoVenda     PedidoVenda    @relation(fields: [pedidoVendaId], references: [id], onDelete: Cascade)
  contaBancaria   ContaBancaria? @relation(fields: [contaBancariaId], references: [id])

  @@index([pedidoVendaId])
}

model PedidoVendaItem {
  id                 String                @id @default(cuid())
  empresaId          String                @default("emp_tramontin")
  pedidoVendaId      String
  itemId             String
  quantidade         Decimal               @db.Decimal(15, 3)
  precoUnitario      Decimal               @db.Decimal(15, 2)
  // Venda à ordem: preço de compra unitário da empresa da venda com a origem
  // (Cimento ← Tramontin). Valora a entrada/saída-origem e o financeiro intragrupo.
  precoTransferencia Decimal?              @db.Decimal(15, 2)
  // Venda à ordem POR ITEM: origem do estoque desta linha (sobrepõe a origem
  // padrão do pedido — ex.: tijolo da Tramontin e cimento da Atlas no mesmo
  // pedido). null = usa PedidoVenda.estoqueOrigemEmpresaId.
  estoqueOrigemEmpresaId String?
  descontoPct        Decimal               @default(0) @db.Decimal(15, 4)
  desconto           Decimal               @default(0) @db.Decimal(15, 2)
  valorDesconto      Decimal               @default(0) @db.Decimal(15, 2)
  valorTotal         Decimal               @db.Decimal(15, 2)
  movimentacoes      MovimentacaoEstoque[]
  minutaItens        MinutaItem[]
  item               Item                  @relation(fields: [itemId], references: [id])
  pedidoVenda        PedidoVenda           @relation(fields: [pedidoVendaId], references: [id], onDelete: Cascade)
  estoqueOrigemEmpresa Empresa?            @relation("PedidoVendaItemEstoqueOrigem", fields: [estoqueOrigemEmpresaId], references: [id])

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@index([itemId])
  @@index([pedidoVendaId])
  @@index([empresaId])
  @@index([estoqueOrigemEmpresaId])
}

// Devolução de venda: cliente devolve itens de um pedido. Resolução por estorno
// (dinheiro de volta), crédito (vale do cliente) ou troca (outro material).
// FKs como colunas escalares (sem relações reversas) para manter o schema enxuto.
enum TipoResolucaoDevolucao {
  ESTORNO
  CREDITO
  TROCA
}

enum StatusDevolucao {
  CONCLUIDA
  CANCELADA
}

model Devolucao {
  id              String                 @id @default(cuid())
  empresaId       String                 @default("emp_tramontin")
  numero          String
  pedidoVendaId   String
  clienteId       String
  data            DateTime               @default(now())
  valorTotal      Decimal                @db.Decimal(15, 2)
  tipoResolucao   TipoResolucaoDevolucao
  status          StatusDevolucao        @default(CONCLUIDA)
  valorAbatidoCr  Decimal?               @db.Decimal(15, 2) // parcela do valor devolvido abatida de CR aberta do pedido
  contaBancariaId String? // estorno: conta de saída do dinheiro
  pedidoTrocaId   String? // troca: novo pedido gerado (fase B3)
  observacoes     String?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  itens           DevolucaoItem[]
  criadoPor       String? // autoria: carimbado automaticamente pelo proxy de sessão
  atualizadoPor   String? // autoria: última edição manual (proxy de sessão)

  @@unique([empresaId, numero])
  @@index([pedidoVendaId])
  @@index([clienteId])
}

model DevolucaoItem {
  id                String    @id @default(cuid())
  devolucaoId       String
  pedidoVendaItemId String
  itemId            String
  quantidade        Decimal   @db.Decimal(15, 3)
  valorUnitario     Decimal   @db.Decimal(15, 2)
  valorTotal        Decimal   @db.Decimal(15, 2)
  devolucao         Devolucao @relation(fields: [devolucaoId], references: [id], onDelete: Cascade)

  @@index([devolucaoId])
}

// Crédito (vale) do cliente — gerado por devolução com resolução CREDITO/TROCA;
// consumido como forma de pagamento em vendas futuras (saldo = valor - valorUsado).
enum StatusCreditoCliente {
  ATIVO
  USADO
  CANCELADO
}

model CreditoCliente {
  id                String               @id @default(cuid())
  empresaId         String               @default("emp_tramontin")
  numero            String
  clienteId         String
  origemDevolucaoId String?
  valor             Decimal              @db.Decimal(15, 2)
  valorUsado        Decimal              @default(0) @db.Decimal(15, 2)
  status            StatusCreditoCliente @default(ATIVO)
  observacoes       String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([empresaId, numero])
  @@index([clienteId])
  @@index([status])
}

model PerfilAcesso {
  id         String    @id @default(cuid())
  nome       String    @unique
  descricao  String?
  permissoes String[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  usuarios   Usuario[]
}

model Permissao {
  id        String  @id @default(cuid())
  usuarioId String
  modulo    String
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, modulo])
  @@index([usuarioId])
}

model ProdutoFornecedor {
  id                String     @id @default(cuid())
  itemId            String
  fornecedorId      String
  codigoFornecedor  String?
  precoUltimo       Decimal?   @db.Decimal(15, 2)
  prazoEntregaDias  Int?
  ativo             Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
  classificacao     String?
  dataUltimaCompra  DateTime?
  especificacao     String?
  indiceFinanceiro  String?
  percentual        Decimal?   @db.Decimal(5, 2)
  qtdeUltimaCompra  Decimal?   @db.Decimal(15, 3)
  tempoResuprimento Int?
  ultimaQtdeDev     Decimal?   @db.Decimal(15, 3)
  unidade           String?
  fornecedor        Fornecedor @relation(fields: [fornecedorId], references: [id])
  item              Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, fornecedorId])
}

// ── Minutas de Entrega ────────────────────────────────────────────────────────

model Motorista {
  id            String   @id @default(cuid())
  nome          String
  cpf           String?
  cnh           String?
  telefone      String?
  ativo         Boolean  @default(true)
  minutas       Minuta[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  criadoPor     String? // autoria: carimbado automaticamente pelo proxy de sessão
  atualizadoPor String? // autoria: última edição manual (proxy de sessão)

  @@index([ativo])
}

// Cadastro próprio de vendedores (independente de ter login no ERP).
// Compartilhado entre as empresas do grupo, como Motorista.
model Vendedor {
  id        String        @id @default(cuid())
  nome      String
  telefone  String?
  ativo     Boolean       @default(true)
  // Vínculo opcional com um usuário do sistema: quando esse usuário cria um
  // pedido de venda, o vendedor é puxado automaticamente.
  usuarioId String?       @unique
  usuario   Usuario?      @relation(fields: [usuarioId], references: [id])
  pedidos   PedidoVenda[]
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([ativo])
}

model Minuta {
  id             String       @id @default(cuid())
  empresaId      String       @default("emp_tramontin")
  numero         String
  numeroFisico   String?
  pedidoVendaId  String
  localEstoqueId String?
  motoristaId    String?
  tipo           TipoMinuta   @default(ENTREGA)
  status         StatusMinuta @default(PENDENTE)
  dataEmissao    DateTime     @default(now())
  dataEntrega    DateTime?
  ordemEntrega   Int?
  placa          String?
  observacoes    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  pedidoVenda  PedidoVenda   @relation(fields: [pedidoVendaId], references: [id])
  localEstoque LocalEstoque? @relation(fields: [localEstoqueId], references: [id])
  motorista    Motorista?    @relation(fields: [motoristaId], references: [id])
  itens        MinutaItem[]

  empresa       Empresa @relation(fields: [empresaId], references: [id])
  criadoPor     String? // autoria: carimbado automaticamente pelo proxy de sessão
  atualizadoPor String? // autoria: última edição manual (proxy de sessão)

  @@unique([empresaId, numero])
  @@index([pedidoVendaId])
  @@index([status])
  @@index([motoristaId])
  @@index([motoristaId, dataEntrega])
  @@index([empresaId])
}

model MinutaItem {
  id                   String   @id @default(cuid())
  empresaId            String   @default("emp_tramontin")
  minutaId             String
  pedidoVendaItemId    String
  itemId               String
  quantidade           Decimal  @db.Decimal(15, 3)
  quantidadeConvertida Decimal? @db.Decimal(15, 3)
  unidadeId            String?

  minuta          Minuta          @relation(fields: [minutaId], references: [id], onDelete: Cascade)
  pedidoVendaItem PedidoVendaItem @relation(fields: [pedidoVendaItemId], references: [id])
  item            Item            @relation(fields: [itemId], references: [id])
  unidade         Unidade?        @relation(fields: [unidadeId], references: [id])

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@index([minutaId])
  @@index([pedidoVendaItemId])
  @@index([empresaId])
}

model Sequencia {
  empresaId String  @default("emp_tramontin")
  prefixo   String
  ultimo    Int     @default(0)
  empresa   Empresa @relation(fields: [empresaId], references: [id])

  @@id([empresaId, prefixo])
}

// ── Tabela de Preços ──────────────────────────────────────────────────────────

model TabelaPreco {
  id                String            @id @default(cuid())
  empresaId         String            @default("emp_tramontin")
  codigo            String
  descricao         String
  dataInicial       DateTime
  dataFinal         DateTime?
  condicaoPagamento String?
  tipoHorario       String            @default("UNICO")
  ativa             Boolean           @default(true)
  ecommerce         Boolean           @default(false)
  markupPadrao      Decimal?          @db.Decimal(8, 4)
  observacoes       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  itens             TabelaPrecoItem[]
  pedidosVenda      PedidoVenda[]

  empresa       Empresa @relation(fields: [empresaId], references: [id])
  criadoPor     String? // autoria: carimbado automaticamente pelo proxy de sessão
  atualizadoPor String? // autoria: última edição manual (proxy de sessão)

  @@unique([empresaId, codigo])
  @@index([ativa])
  @@index([empresaId])
}

model TabelaPrecoItem {
  id            String      @id @default(cuid())
  tabelaPrecoId String
  sequencia     Int
  itemId        String?
  grupo         String?
  precoBase     Decimal     @default(0) @db.Decimal(15, 4)
  precoVenda    Decimal     @default(0) @db.Decimal(15, 4)
  vlrDesconto   Decimal     @default(0) @db.Decimal(15, 4)
  markupPct     Decimal?    @db.Decimal(8, 4) // % sobre o custo da empresa; null = preço manual
  ativo         Boolean     @default(true)
  fator         Decimal     @default(0) @db.Decimal(15, 4)
  tipoOperacao  String?
  faixa         Decimal?    @db.Decimal(15, 2)
  moeda         String      @default("BRL")
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tabelaPreco   TabelaPreco @relation(fields: [tabelaPrecoId], references: [id], onDelete: Cascade)
  item          Item?       @relation(fields: [itemId], references: [id])

  @@index([tabelaPrecoId])
  @@index([itemId])
}

model TipoProduto {
  id        String   @id @default(cuid())
  nome      String
  descricao String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  itens     Item[]
}

model Unidade {
  id                        String                     @id @default(cuid())
  nome                      String
  sigla                     String                     @unique
  ativo                     Boolean                    @default(true)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  itens                     Item[]
  itemUnidadesBase          ItemUnidade[]              @relation("ItemUnidade_baseUnidadeIdToUnidade")
  itemUnidades              ItemUnidade[]              @relation("ItemUnidade_unidadeIdToUnidade")
  movimentacoes             MovimentacaoEstoque[]
  minutaItens               MinutaItem[]
  conversoesDestino         UnidadeConversao[]         @relation("UnidadeConversao_unidadeDestinoIdToUnidade")
  ordemProducaoProdutoItens OrdemProducaoProdutoItem[]
  conversoesOrigem          UnidadeConversao[]         @relation("UnidadeConversao_unidadeOrigemIdToUnidade")
}

model UnidadeConversao {
  id               String   @id @default(cuid())
  unidadeOrigemId  String
  unidadeDestinoId String
  fator            Decimal  @db.Decimal(18, 6)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  unidadeDestino   Unidade  @relation("UnidadeConversao_unidadeDestinoIdToUnidade", fields: [unidadeDestinoId], references: [id], onDelete: Cascade)
  unidadeOrigem    Unidade  @relation("UnidadeConversao_unidadeOrigemIdToUnidade", fields: [unidadeOrigemId], references: [id], onDelete: Cascade)

  @@unique([unidadeOrigemId, unidadeDestinoId])
}

model Usuario {
  id                 String           @id @default(cuid())
  nome               String
  email              String           @unique
  senha              String
  perfil             PerfilUsuario    @default(USUARIO)
  ativo              Boolean          @default(true)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  perfilAcessoId     String?
  telefone           String?
  aprovacaoEtapas    AprovacaoEtapa[]
  aprovacoesSC       AprovacaoSC[]
  colaborador        Colaborador?
  permissoes         Permissao[]
  perfilAcesso       PerfilAcesso?    @relation(fields: [perfilAcessoId], references: [id])
  ticketsAbertos     SupportTicket[]  @relation("TicketsAbertos")
  ticketsRespondidos SupportTicket[]  @relation("TicketsRespondidos")
  empresas           UsuarioEmpresa[]
  vendedor           Vendedor?
  sessoes            UsuarioSessao[]
  notificacoes       Notificacao[]
}

// Sessão/dispositivo logado de um usuário. id = jti embutido no JWT. Permite
// listar os dispositivos conectados e revogar (deslogar) cada um remotamente.
model UsuarioSessao {
  id             String    @id // = jti (uuid) embutido no token
  usuarioId      String
  userAgent      String?
  dispositivo    String?
  navegador      String?
  so             String?
  ip             String?
  criadoEm       DateTime  @default(now())
  ultimoAcessoEm DateTime  @default(now())
  expiraEm       DateTime
  revogadoEm     DateTime?
  usuario        Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([revogadoEm])
}

// Vínculo usuário ↔ empresa (multiempresa, Fase 3). ADMIN enxerga todas as
// empresas ativas; USUARIO só as vinculadas aqui (sem vínculo = só Tramontin).
model UsuarioEmpresa {
  id        String  @id @default(cuid())
  usuarioId String
  empresaId String
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  empresa   Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, empresaId])
  @@index([empresaId])
}

// Criticidade (A/B/C) de um ativo do Engeman. Os ativos vivem no Engeman
// (somente leitura, tabela APLIC); aqui guardamos só a classificação, mapeada
// pelo CODAPL (chave estável usada em FMEA/indicadores). Sem registro = "não
// classificado". Alimenta os relatórios futuros focados em criticidade A.
model AtivoCriticidade {
  id              String      @id @default(cuid())
  codApl          Int         @unique
  criticidade     Criticidade
  tag             String?
  descricao       String?
  classificadoPor String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
}

// Regime de operação por ativo (horas/dia). Pré-preenche o tempo de funcionamento
// no fechamento mensal de MTBF (mês = dias do mês × horasPorDia).
model AtivoRegime {
  id          String   @id @default(cuid())
  codApl      Int      @unique
  horasPorDia Float    @default(24)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Fechamento mensal validado de MTBF/MTTR por ativo. Pré-preenchido do Engeman
// (falhas, parada não planejada) + regime (funcionamento); o usuário ajusta e
// "fecha". Só meses fechados entram no relatório oficial "Ativo Saúde".
model FechamentoMtbf {
  id                      String    @id @default(cuid())
  codApl                  Int
  ano                     Int
  mes                     Int
  horasFuncionamento      Float
  horasParadaNaoPlanejada Float
  numeroFalhas            Int
  fechado                 Boolean   @default(false)
  fechadoPor              String?
  fechadoEm               DateTime?
  observacao              String?
  tag                     String?
  descricao               String?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@unique([codApl, ano, mes])
}

enum Criticidade {
  A
  B
  C
}

// ═══════════════════════════════════════════════════════════════════════════
// PCP — Planejamento e Controle da Produção
// ═══════════════════════════════════════════════════════════════════════════

// Centro de trabalho (preparação, conformação, secagem, forno, embalagem...).
// Pode apontar opcionalmente para um ativo do Engeman (forno/secador) via codApl
// (sem FK — mesma convenção de AtivoCriticidade/AtivoRegime).
model CentroTrabalho {
  id                String              @id @default(cuid())
  codigo            String              @unique
  nome              String
  tipo              TipoCentroTrabalho?
  codApl            Int?
  capacidadePadrao  Decimal?            @db.Decimal(15, 3)
  unidadeCapacidade String?
  ativo             Boolean             @default(true)
  observacao        String?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  @@index([codApl])
}

// Fluxo de produção (roteiro) — opcionalmente vinculado a um produto acabado (Item).
// Versionado; a versão publicada vigente fica em versaoAtivaId.
model FluxoProducao {
  id            String                @id @default(cuid())
  nome          String
  descricao     String?
  itemId        String?
  ativo         Boolean               @default(true)
  versaoAtivaId String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  item          Item?                 @relation(fields: [itemId], references: [id])
  versoes       FluxoProducaoVersao[]
  engenharias   EngenhariaProduto[]

  @@index([itemId])
}

// Versão imutável do grafo desenhado. grafo = { nodes, edges } do React Flow
// (fonte de verdade). A projeção normalizada (operações/insumos) entra na Fase 2.
model FluxoProducaoVersao {
  id              String            @id @default(cuid())
  fluxoProducaoId String
  versao          Int
  status          StatusFluxoVersao @default(RASCUNHO)
  grafo           Json
  publicadoPor    String?
  publicadoEm     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  fluxo           FluxoProducao     @relation(fields: [fluxoProducaoId], references: [id], onDelete: Cascade)
  ordens          OrdemProducao[]

  @@unique([fluxoProducaoId, versao])
  @@index([fluxoProducaoId])
}

enum TipoCentroTrabalho {
  PREPARACAO
  CONFORMACAO
  SECAGEM
  FORNO
  EMBALAGEM
  TRANSPORTE
  OUTRO
}

enum StatusFluxoVersao {
  RASCUNHO
  PUBLICADA
  ARQUIVADA
}

// Tipos de nó do editor — usados dentro do grafo JSON e no código do editor
// (gerados no client Prisma como enums TS; ainda sem coluna dedicada).
enum KindNo {
  ESTOQUE_INSUMO
  OPERACAO
  TRANSPORTE
  BUFFER_WIP
  INSPECAO
  ESTOCAGEM_PA
}

// Estados de WIP do processo (úmido → seco → queimado → acabado).
enum EstadoWIP {
  UMIDO
  SECO
  QUEIMADO
  ACABADO
}

// Veículos de movimentação do WIP dentro da fábrica.
enum VeiculoMovimentacao {
  VAGONETA
  VAGAO
}

// Capacidade de carga (peças) de um produto por veículo. Um veículo pode levar
// vários produtos, cada um com a sua capacidade.
model ItemCargaVeiculo {
  id         String              @id @default(cuid())
  itemId     String
  veiculo    VeiculoMovimentacao
  capacidade Int
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  item       Item                @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, veiculo])
  @@index([itemId])
}

// Quais veículos cada ETAPA (nome da operação do fluxo: Conformação, Secagem, …)
// usa. Ex.: Conformação→VAGONETA; Secagem→VAGONETA e VAGAO; Queima→VAGAO.
model EtapaVeiculo {
  id        String              @id @default(cuid())
  etapa     String
  veiculo   VeiculoMovimentacao
  createdAt DateTime            @default(now())

  @@unique([etapa, veiculo])
}

// Catálogo configurável de estados de WIP (úmido, seco, queimado, acabado, …).
// O produto declara quais atende (Item.estadosWip) e o bloco de WIP do fluxo
// filtra os produtos por esse estado. Independente do enum EstadoWIP (legado de
// apontamento/estoque), que segue valendo para os 4 estados base.
model EstadoWip {
  id        String   @id @default(cuid())
  codigo    String   @unique
  nome      String
  ordem     Int      @default(0)
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Parâmetros de custeio por competência: insumos indiretos (biomassa, energia,
// combustível) e mão de obra (folha) usados para derivar a taxa predeterminada de
// CIF e MOD por milheiro. O volume vem das entradas (manuais) no estoque de PA.
model ParametroCusteio {
  id              String   @id @default(cuid())
  empresaId       String   @default("emp_tramontin")
  competencia     DateTime // 1º dia do mês de referência
  biomassaDia     Decimal  @default(0) @db.Decimal(15, 2)
  energiaMes      Decimal  @default(0) @db.Decimal(15, 2)
  combustivelDia  Decimal  @default(0) @db.Decimal(15, 2)
  folhaMes        Decimal  @default(0) @db.Decimal(15, 2) // mão de obra DIRETA (MOD)
  folhaMoiMes     Decimal  @default(0) @db.Decimal(15, 2) // mão de obra INDIRETA (MOI) → entra no CIF
  depreciacaoMes  Decimal  @default(0) @db.Decimal(15, 2) // depreciação/amortização fabril → entra no CIF
  diaristasMes    Decimal  @default(0) @db.Decimal(15, 2) // diaristas diretos → entra no MOD
  diasTrabalhados Int      @default(26)
  observacao      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  empresa         Empresa  @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, competencia])
  @@index([empresaId])
}

// Histórico do custo de produção de um produto por competência (gravado ao aplicar
// o custeio): acompanha a evolução de material + MOD + CIF ao longo do tempo.
model ItemCustoHistorico {
  id               String   @id @default(cuid())
  empresaId        String   @default("emp_tramontin")
  itemId           String
  competencia      DateTime
  materialMilheiro Decimal  @default(0) @db.Decimal(15, 4)
  modMilheiro      Decimal  @default(0) @db.Decimal(15, 4)
  cifMilheiro      Decimal  @default(0) @db.Decimal(15, 4)
  custoUnitario    Decimal  @default(0) @db.Decimal(15, 4)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([empresaId, itemId, competencia])
  @@index([itemId])
}

// Ordem de produção — executa uma versão publicada de um fluxo. As etapas são
// um snapshot (em ordem topológica) das operações do grafo no momento da criação.
model OrdemProducao {
  id                       String                     @id @default(cuid())
  empresaId                String                     @default("emp_tramontin")
  numero                   String
  itemId                   String?
  fluxoVersaoId            String
  quantidadePlanejada      Decimal                    @db.Decimal(15, 3)
  unidade                  String?
  status                   StatusOrdemProducao        @default(RASCUNHO)
  estadoAtual              EstadoWIP                  @default(UMIDO)
  dataPrevista             DateTime?
  dataPrevistaInicio       DateTime?
  dataPrevistaFim          DateTime?
  responsavelColaboradorId String?
  observacao               String?
  // Planejamento por transporte (vagões/vagonetas): linhas {veiculo, nVagoes,
  // cargas:[{itemId, pecas}]} do dialog "Planejar por transporte". Persistido p/
  // reabrir a OP com a configuração e imprimir o apontamento por vagão.
  planoTransporte          Json?
  criadoPor                String?
  createdAt                DateTime                   @default(now())
  updatedAt                DateTime                   @updatedAt
  item                     Item?                      @relation(fields: [itemId], references: [id])
  fluxoVersao              FluxoProducaoVersao        @relation(fields: [fluxoVersaoId], references: [id])
  responsavelColaborador   Colaborador?               @relation("OrdemProducaoResponsavel", fields: [responsavelColaboradorId], references: [id])
  produtoItens             OrdemProducaoProdutoItem[]
  etapas                   ItemOrdemProducao[]
  consumos                 ConsumoBiomassa[]
  movimentacoes            MovimentacaoEstoque[]
  anexos                   OrdemProducaoAnexo[]
  equipe                   OrdemProducaoEquipe[]

  empresa       Empresa @relation(fields: [empresaId], references: [id])
  atualizadoPor String? // autoria: última edição manual (proxy de sessão)

  @@unique([empresaId, numero])
  @@index([status])
  @@index([itemId])
  @@index([fluxoVersaoId])
  @@index([empresaId])
}

// Equipe da OP: colaboradores que estavam na produção no dia. A OP é do DIA
// (uma só, com todas as pessoas), não por pessoa — o responsável continua no
// campo próprio; aqui fica o restante da equipe.
model OrdemProducaoEquipe {
  id              String        @id @default(cuid())
  ordemProducaoId String
  colaboradorId   String
  ordemProducao   OrdemProducao @relation(fields: [ordemProducaoId], references: [id], onDelete: Cascade)
  colaborador     Colaborador   @relation(fields: [colaboradorId], references: [id])

  @@unique([ordemProducaoId, colaboradorId])
  @@index([colaboradorId])
}

// Arquivos anexados à OP (ex.: OP escaneada/assinada como comprovação). Vercel Blob.
model OrdemProducaoAnexo {
  id              String        @id @default(cuid())
  ordemProducaoId String
  nome            String
  url             String
  tamanho         Int
  tipo            String
  criadoPor       String?
  createdAt       DateTime      @default(now())
  ordemProducao   OrdemProducao @relation(fields: [ordemProducaoId], references: [id], onDelete: Cascade)

  @@index([ordemProducaoId])
}

// Produtos (linhas) de uma OP — uma OP pode produzir VÁRIOS produtos. quantidade na
// unidade escolhida (unidadeId; null = base). quantidadeReal preenchida no apontamento.
model OrdemProducaoProdutoItem {
  id                  String        @id @default(cuid())
  ordemProducaoId     String
  itemId              String
  quantidadePlanejada Decimal       @db.Decimal(15, 3)
  unidadeId           String?
  quantidadeReal      Decimal?      @db.Decimal(15, 3)
  // Perda POR PRODUTO (peças): descarregado dos vagões − apontado. A perda da etapa
  // (ItemOrdemProducao.qtdPerda) guarda a soma; aqui fica a quebra por produto.
  qtdPerda            Decimal?      @db.Decimal(15, 3)
  createdAt           DateTime      @default(now())
  ordemProducao       OrdemProducao @relation(fields: [ordemProducaoId], references: [id], onDelete: Cascade)
  item                Item          @relation("OrdemProducaoProdutoItem_item", fields: [itemId], references: [id])
  unidade             Unidade?      @relation(fields: [unidadeId], references: [id])

  @@index([ordemProducaoId])
}

// Uma etapa apontável da ordem (snapshot de um nó de operação/transporte/inspeção).
model ItemOrdemProducao {
  id                  String        @id @default(cuid())
  empresaId           String        @default("emp_tramontin")
  ordemProducaoId     String
  nodeId              String
  sequencia           Int
  nome                String
  kind                KindNo
  centroTrabalho      String?
  estadoSaida         EstadoWIP?
  tempoCicloHoras     Decimal?      @db.Decimal(15, 3)
  subprodutoItemId    String?
  subprodutoDescricao String?
  insumos             Json? // [{ itemId, descricao, consumoPorMilheiro }] — custeio por fase
  status              StatusEtapaOP @default(PENDENTE)
  qtdEntrada          Decimal?      @db.Decimal(15, 3)
  qtdSaida            Decimal?      @db.Decimal(15, 3)
  qtdPerda            Decimal?      @db.Decimal(15, 3)
  vagoes              Int?
  vagonetas           Int?
  inicioReal          DateTime?
  fimReal             DateTime?
  apontadoPor         String?
  observacao          String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  ordemProducao       OrdemProducao @relation(fields: [ordemProducaoId], references: [id], onDelete: Cascade)

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@index([ordemProducaoId])
  @@index([status])
  @@index([empresaId])
}

// Consumo de biomassa (caroço de açaí) apontado na queima — alimenta KPI por milheiro.
model ConsumoBiomassa {
  id                  String        @id @default(cuid())
  empresaId           String        @default("emp_tramontin")
  ordemProducaoId     String
  itemOrdemProducaoId String?
  descricao           String?
  quantidadeKg        Decimal       @db.Decimal(15, 3)
  milheirosProduzidos Decimal?      @db.Decimal(15, 3)
  data                DateTime      @default(now())
  registradoPor       String?
  createdAt           DateTime      @default(now())
  ordemProducao       OrdemProducao @relation(fields: [ordemProducaoId], references: [id], onDelete: Cascade)

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@index([ordemProducaoId])
  @@index([empresaId])
}

enum StatusOrdemProducao {
  RASCUNHO
  LIBERADA
  EM_PRODUCAO
  CONCLUIDA
  CANCELADA
}

enum StatusEtapaOP {
  PENDENTE
  EM_EXECUCAO
  CONCLUIDA
}

// Engenharia/estrutura do produto: liga um produto acabado a um fluxo (compartilhado)
// e à sua lista de insumos (BOM). O fluxo é o "caminho"; a engenharia é "o que entra".
model EngenhariaProduto {
  id         String             @id @default(cuid())
  itemId     String             @unique
  fluxoId    String
  ativo      Boolean            @default(true)
  observacao String?
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt
  item       Item               @relation("EngenhariaProdutoItem", fields: [itemId], references: [id])
  fluxo      FluxoProducao      @relation(fields: [fluxoId], references: [id])
  insumos    EngenhariaInsumo[]

  @@index([fluxoId])
}

// Linha de BOM: um insumo (Item real) com quantidade por base. Categoria distingue
// matéria-prima, mistura (semi-acabado), embalagem (pallet/fita/grampo) e energia.
model EngenhariaInsumo {
  id            String            @id @default(cuid())
  engenhariaId  String
  insumoItemId  String
  quantidade    Decimal           @db.Decimal(15, 3)
  base          BaseConsumo       @default(POR_MILHEIRO)
  categoria     CategoriaInsumo   @default(MATERIA_PRIMA)
  // Unidade em que a quantidade está expressa (id de Unidade); null = unidade-base do item.
  unidadeId     String?
  // Fase/estado em que o insumo é consumido (custeio por fase); null = primeira etapa.
  estadoConsumo EstadoWIP?
  observacao    String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  engenharia    EngenhariaProduto @relation(fields: [engenhariaId], references: [id], onDelete: Cascade)
  insumoItem    Item              @relation("EngenhariaInsumoItem", fields: [insumoItemId], references: [id])

  @@index([engenhariaId])
  @@index([insumoItemId])
}

enum BaseConsumo {
  POR_MILHEIRO
  POR_UNIDADE
  POR_CICLO
  POR_VAGAO
  POR_PALETE
}

enum CategoriaInsumo {
  MATERIA_PRIMA
  MISTURA
  EMBALAGEM
  ENERGIA
  OUTRO
}

// Plano Mestre (MPS): demanda/produção planejada de um produto acabado por período.
// origem = de onde veio a demanda (manual é o padrão; pedidos/mín-máx são opcionais).
model PlanoMestre {
  id         String        @id @default(cuid())
  empresaId  String        @default("emp_tramontin")
  itemId     String
  periodo    String // AAAA-MM (mês de planejamento)
  quantidade Decimal       @db.Decimal(15, 3)
  origem     OrigemDemanda @default(MANUAL)
  observacao String?
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  item       Item          @relation(fields: [itemId], references: [id], onDelete: Cascade)

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@index([itemId])
  @@index([periodo])
  @@index([empresaId])
}

enum OrigemDemanda {
  MANUAL
  PEDIDO_VENDA
  MIN_MAX
}

// Meta de produção do DIA por produto acabado — base da "rotina diária" que gera
// as OPs do dia. Pode ser MANUAL ou derivada do MPS mensal (rateio por dias úteis).
model MetaProducaoDiaria {
  id         String           @id @default(cuid())
  empresaId  String           @default("emp_tramontin")
  itemId     String
  data       DateTime         @db.Date
  quantidade Decimal          @db.Decimal(15, 3)
  origem     OrigemMetaDiaria @default(MANUAL)
  observacao String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  item       Item             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  empresa    Empresa          @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, itemId, data])
  @@index([data])
  @@index([itemId])
  @@index([empresaId])
}

enum OrigemMetaDiaria {
  MANUAL
  MPS
}

enum PerfilUsuario {
  ADMIN
  USUARIO
}

enum ProcessoAprovacao {

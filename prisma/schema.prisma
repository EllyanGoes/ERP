// ─────────────────────────────────────────────────────────────────────────────
// Inteligência Comercial (IC) — Marketing
//
// Cadastro de concorrentes de mercado: categoria (fornecedor e/ou revendedor),
// endereço, geolocalização (geomarketing) e mapeamento dos preços praticados
// por produto. Preços referenciam o nosso catálogo (Item) quando possível, com
// fallback de produto avulso por texto livre.
// ─────────────────────────────────────────────────────────────────────────────

model Concorrente {
  id           String     @id @default(cuid())
  empresaId    String     @default("emp_tramontin")
  tipoPessoa   TipoPessoa @default(JURIDICA)
  razaoSocial  String
  nomeFantasia String?
  cpfCnpj      String?

  // Vínculo opcional: concorrente que também é um cliente cadastrado. Apenas
  // referência (sem FK forte) para registrar a origem e exibir o selo cruzado.
  clienteId String?

  // Parceria comercial (estrela no mapa). Independente do vínculo clienteId —
  // dá pra desfazer a parceria sem perder o vínculo com a base de clientes.
  ehParceiro Boolean @default(false)

  // Categoria — fornecedor, revendedor, construtora e/ou consumidor final (pode ser vários).
  ehFornecedor      Boolean @default(false)
  ehRevendedor      Boolean @default(false)
  ehConstrutora     Boolean @default(false)
  ehConsumidorFinal Boolean @default(false)

  // Contato
  email    String?
  telefone String?
  celular  String?
  site     String?

  // Endereço (mesma decomposição de Cliente/Fornecedor)
  cep         String?
  logradouro  String?
  numero      String?
  complemento String?
  bairro      String?
  cidade      String?
  estado      String?

  // Geolocalização (geomarketing). Preenchida por geocodificação (Nominatim/OSM)
  // ou ajuste manual. Float p/ chegar ao front como número puro.
  latitude      Float?
  longitude     Float?
  // Quando true, as coordenadas foram fixadas manualmente (pino arrastado ou
  // coladas do Google Maps) — o geocoding automático não as sobrescreve.
  geoManual     Boolean @default(false)
  // Referência crua do ajuste manual: a URL do Google Maps ou o "lat, lng"
  // informado/arrastado. Mantida para conferência e reuso.
  geoReferencia String?

  observacoes String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  empresa  Empresa              @relation(fields: [empresaId], references: [id])
  precos   ConcorrentePreco[]
  contatos ConcorrenteContato[]
  canais   ConcorrenteCanal[]

  @@index([empresaId])
  @@index([cidade])
  @@index([ativo])
  @@index([clienteId])
}

// Um concorrente pode ter vários contatos (vendedor, gerente, dono...).
model ConcorrenteContato {
  id            String      @id @default(cuid())
  empresaId     String      @default("emp_tramontin")
  concorrenteId String
  nome          String
  cargo         String?
  telefone      String?
  email         String?
  observacao    String?
  createdAt     DateTime    @default(now())
  concorrente   Concorrente @relation(fields: [concorrenteId], references: [id], onDelete: Cascade)

  @@index([concorrenteId])
}

// Canais de aquisição de clientes do concorrente. A localização física conta
// como um canal (tipo LOCALIZACAO); demais: INSTAGRAM, SITE, WHATSAPP, etc.
// `tipo` é String (não enum) p/ permitir novos canais sem migração.
// Quando tipo=LOCALIZACAO, o canal é um ponto físico (filial/depósito) com
// endereço + coordenadas e vai pro mapa do geomarketing.
model ConcorrenteCanal {
  id            String      @id @default(cuid())
  empresaId     String      @default("emp_tramontin")
  concorrenteId String
  tipo          String
  valor         String? // link/@perfil/número/descrição (ou nome do local)
  observacao    String?
  // Geo — só p/ tipo=LOCALIZACAO.
  cep           String?
  logradouro    String?
  numero        String?
  complemento   String?
  bairro        String?
  cidade        String?
  estado        String?
  latitude      Float?
  longitude     Float?
  geoManual     Boolean     @default(false)
  geoReferencia String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @default(now()) @updatedAt
  concorrente   Concorrente @relation(fields: [concorrenteId], references: [id], onDelete: Cascade)

  @@index([concorrenteId])
}

model ConcorrentePreco {
  id            String @id @default(cuid())
  empresaId     String @default("emp_tramontin")
  concorrenteId String

  // Vínculo opcional com o nosso catálogo. Quando nulo, é produto avulso
  // identificado apenas por produtoNome.
  itemId      String?
  produtoNome String

  preco             Decimal  @db.Decimal(15, 2)
  unidade           String?
  // Condições que fazem o preço variar — permitem mais de um preço por produto.
  condicaoPagamento String? // ex.: "À vista", "30 dias", "30/60/90"
  modalidade        String? // "ENTREGA" | "RETIRADA" | null (indiferente)
  dataColeta        DateTime @default(now())
  observacao        String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  empresa     Empresa     @relation(fields: [empresaId], references: [id])
  concorrente Concorrente @relation(fields: [concorrenteId], references: [id], onDelete: Cascade)
  item        Item?       @relation(fields: [itemId], references: [id])

  @@index([empresaId])
  @@index([concorrenteId])
  @@index([itemId])
}

// ── Marketing: Funis, Campanhas, Leads e Tracking (PRD docs/marketing-funis-prd.md) ──
// Como a Inteligência Comercial, TODOS estes models são compartilhados pelo
// grupo (fora de MODELOS_ESCOPADOS); empresaId é só tag de origem.

enum StatusFunil {
  RASCUNHO
  ATIVO
  ARQUIVADO
}

model Funil {
  id              String      @id @default(cuid())
  empresaId       String      @default("emp_tramontin")
  nome            String
  descricao       String?
  status          StatusFunil @default(RASCUNHO)
  // Grafo do React Flow ({ nodes, edges }) — desenho livre, sem joins.
  // O espelho consultável dos nós é FunilNo, sincronizado no save.
  canvas          Json        @default("{\"nodes\":[],\"edges\":[]}")
  // Parâmetros globais de forecast (período, volume padrão).
  forecast        Json?
  ativo           Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  criadoPor       String?
  atualizadoPor   String?
  empresa         Empresa     @relation(fields: [empresaId], references: [id])
  nos             FunilNo[]
  leads           Lead[]
  lancamentos     LancamentoManualMetrica[]
  metricasDiarias MetricaNoDiaria[]

  @@index([status])
  @@index([ativo])
}

enum TipoFunilNo {
  FONTE
  PAGINA
  ACAO
  ETAPA_OFFLINE
}

// Espelho flat dos nós do canvas — escrito SOMENTE pelo PUT do funil (mesma
// transação do save). Soft-delete (ativo=false) preserva métricas de nós
// removidos do desenho. `config` copia o node.data relevante p/ matching:
//   PAGINA        → { urlPatterns: ["/lp-promo*"] }
//   ACAO          → { eventoNome: "form_submit" }
//   FONTE         → { plataforma, campanhaId? }
//   ETAPA_OFFLINE → { etapaLeadId?, vinculoErp? }
model FunilNo {
  id      String      @id @default(cuid())
  funilId String
  noId    String // id do node no JSON do React Flow (estável entre saves)
  tipo    TipoFunilNo
  rotulo  String
  config  Json?
  ativo   Boolean     @default(true)
  funil   Funil       @relation(fields: [funilId], references: [id], onDelete: Cascade)

  @@unique([funilId, noId])
  @@index([tipo])
}

// Campanha de aquisição. `plataforma` é String (não enum) p/ novos canais sem
// migração — padrão ConcorrenteCanal.tipo. utmCampaign é a chave do matching
// UTM→campanha na ingestão do tracking (case-insensitive).
model Campanha {
  id            String    @id @default(cuid())
  empresaId     String    @default("emp_tramontin")
  nome          String
  plataforma    String // META | GOOGLE | TIKTOK | ORGANICO | INDICACAO | WHATSAPP | OUTRO
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  idExterno     String? // id da campanha na plataforma de ads (Fase 5)
  orcamento     Decimal?  @db.Decimal(15, 2)
  dataInicio    DateTime?
  dataFim       DateTime?
  observacoes   String?
  ativo         Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  criadoPor     String?
  atualizadoPor String?
  empresa       Empresa   @relation(fields: [empresaId], references: [id])
  leads         Lead[]
  sessoes       TrackingSessao[]
  metricasAds   MetricaCampanhaDiaria[]

  @@index([utmCampaign])
  @@index([plataforma])
  @@index([ativo])
}

// Pipeline de leads configurável (colunas do kanban) — global ao grupo.
model EtapaLead {
  id    String  @id @default(cuid())
  nome  String
  ordem Int     @default(0)
  cor   String? // hex da coluna no kanban
  ganho Boolean @default(false) // etapa terminal de sucesso
  ativo Boolean @default(true)
  leads Lead[]
}

enum StatusLead {
  ABERTO
  GANHO
  PERDIDO
}

model Lead {
  id            String     @id @default(cuid())
  empresaId     String     @default("emp_tramontin")
  nome          String
  email         String?
  telefone      String?
  empresaNome   String? // empresa do lead (texto livre)
  cidade        String?
  estado        String?
  status        StatusLead @default(ABERTO)
  motivoPerda   String?
  valorEstimado Decimal?   @db.Decimal(15, 2)
  // Origem / atribuição
  campanhaId    String?
  utmSource     String?
  utmMedium     String?
  utmCampaign   String?
  origemLivre   String? // "indicação do fulano", quando sem campanha
  // Pipeline
  funilId       String?
  etapaId       String?
  // Conversão no ERP
  clienteId     String?
  pedidoVendaId String? // primeiro pedido gerado
  convertidoEm  DateTime?
  // Ponte com o tracking (identify por email, Fase 3)
  visitanteId   String?
  responsavelId String? // Usuario responsável pelo follow-up (sem FK, padrão criadoPor)
  observacoes   String?
  ativo         Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  criadoPor     String?
  atualizadoPor String?
  empresa       Empresa      @relation(fields: [empresaId], references: [id])
  campanha      Campanha?    @relation(fields: [campanhaId], references: [id])
  funil         Funil?       @relation(fields: [funilId], references: [id])
  etapa         EtapaLead?   @relation(fields: [etapaId], references: [id])
  cliente       Cliente?     @relation(fields: [clienteId], references: [id])
  pedidoVenda   PedidoVenda? @relation(fields: [pedidoVendaId], references: [id])
  eventos       LeadEvento[]

  @@index([status])
  @@index([etapaId])
  @@index([campanhaId])
  @@index([funilId])
  @@index([clienteId])
  @@index([email])
  @@index([visitanteId])
}

// Timeline do lead (criação, mudança de etapa, notas, conversões).
model LeadEvento {
  id        String   @id @default(cuid())
  leadId    String
  tipo      String // CRIACAO | MUDANCA_ETAPA | NOTA | CONTATO | GANHO | PERDIDO | CONVERSAO_CLIENTE | CONVERSAO_PEDIDO
  descricao String?
  dados     Json? // { deEtapaId, paraEtapaId } etc.
  criadoPor String?
  createdAt DateTime @default(now())
  lead      Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

// ── Tracking web (Fase 3 — tabelas criadas desde já; volume alto → mínimo de colunas) ──

// Site com o snippet instalado. `id` é o siteId público do snippet; `dominios`
// é a allowlist p/ validação de Origin/CORS na ingestão (fail-closed).
model SiteRastreado {
  id        String   @id @default(cuid())
  nome      String
  dominios  String[] @default([])
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
}

model TrackingVisitante {
  id         String   @id // cuid gerado pelo snippet (cookie _erp_vid)
  leadId     String? // preenchido no "identify" (form com email)
  primeiroEm DateTime @default(now())
  ultimoEm   DateTime @default(now())

  @@index([leadId])
}

model TrackingSessao {
  id          String    @id // gerado pelo snippet (cookie _erp_sid)
  visitanteId String
  siteId      String
  inicio      DateTime  @default(now())
  ultimoEm    DateTime  @default(now())
  referrer    String?
  // UTMs capturadas no 1º pageview da sessão
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  utmTerm     String?
  utmContent  String?
  campanhaId  String? // resolvido na ingestão (match utmCampaign / ?cid=)
  dispositivo String? // "mobile" | "desktop" (derivado do UA; UA cru NÃO armazenado)
  campanha    Campanha? @relation(fields: [campanhaId], references: [id])

  @@index([visitanteId])
  @@index([campanhaId])
  @@index([inicio])
}

model TrackingEvento {
  id          String   @id @default(cuid())
  sessaoId    String
  visitanteId String // desnormalizado p/ agregação sem join
  siteId      String
  tipo        String // "pageview" | "evento"
  nome        String? // nome do evento custom (tipo=evento)
  path        String // pathname normalizado (sem querystring)
  createdAt   DateTime @default(now())

  @@index([createdAt]) // purge/agregação por dia
  @@index([siteId, path, createdAt]) // matching URL→nó
  @@index([sessaoId])
  @@index([visitanteId, createdAt]) // path-analysis (Fase 4)
}

// Agregado diário por nó — o canvas (modo análise) lê DAQUI, nunca dos eventos
// crus. Populado pelo cron marketing-agrega-tracking (fontes TRACKING/ERP/ADS).
model MetricaNoDiaria {
  id         String   @id @default(cuid())
  funilId    String
  noId       String // FunilNo.noId
  data       DateTime @db.Date
  fonte      String // "TRACKING" | "ERP" | "ADS"
  visitantes Int      @default(0) // únicos no dia
  sessoes    Int      @default(0)
  eventos    Int      @default(0) // pageviews/eventos totais
  conversoes Int      @default(0) // p/ nós ERP: qtde pedidos/clientes novos
  receita    Decimal  @default(0) @db.Decimal(15, 2)
  funil      Funil    @relation(fields: [funilId], references: [id], onDelete: Cascade)

  @@unique([funilId, noId, data, fonte])
  @@index([funilId, data])
}

// Lançamento manual de métricas por nó/período (alcance do anúncio, contatos no
// WhatsApp...) — auditável, consultado à parte do agregado (fonte MANUAL).
model LancamentoManualMetrica {
  id         String   @id @default(cuid())
  empresaId  String   @default("emp_tramontin")
  funilId    String
  noId       String
  dataInicio DateTime @db.Date
  dataFim    DateTime @db.Date
  visitantes Int? // métricas nulláveis — lança só o que tem
  leads      Int?
  conversoes Int?
  receita    Decimal? @db.Decimal(15, 2)
  observacao String?
  createdAt  DateTime @default(now())
  criadoPor  String?
  empresa    Empresa  @relation(fields: [empresaId], references: [id])
  funil      Funil    @relation(fields: [funilId], references: [id], onDelete: Cascade)

  @@index([funilId, noId, dataInicio])
}

// Métricas importadas das APIs de ads (Meta/Google/TikTok — Fase 5).
model MetricaCampanhaDiaria {
  id         String   @id @default(cuid())
  campanhaId String
  data       DateTime @db.Date
  spend      Decimal  @default(0) @db.Decimal(15, 2)
  impressoes Int      @default(0)
  cliques    Int      @default(0)
  conversoes Int      @default(0)
  bruto      Json? // payload cru da API p/ auditoria
  campanha   Campanha @relation(fields: [campanhaId], references: [id], onDelete: Cascade)

  @@unique([campanhaId, data])
  @@index([data])
}

// ── Lixeira de documentos ─────────────────────────────────────────────────────
// Snapshot COMPLETO gravado no início da transação de cada DELETE destrutivo
// (documento + filhos + vínculos) — permite consultar e restaurar exclusões
// acidentais (caso MIN-0201, jul/2026). `tipo` é String livre (aditivo);
// retenção de 90 dias via cron limpar-lixeira. Restauração marca restauradoEm
// e o id do documento recriado.
model Lixeira {
  id               String    @id @default(cuid())
  empresaId        String    @default("emp_tramontin")
  tipo             String // PEDIDO_VENDA | MINUTA | PEDIDO_COMPRA | COTACAO_COMPRA | CONFERENCIA_COMPRA | ORDEM_PRODUCAO | CONTA_BANCARIA
  origemId         String // id original do documento apagado
  numero           String? // MIN-0201 / PV-0238… para busca rápida
  descricao        String? // resumo humano (cliente · itens · valor)
  snapshot         Json // documento completo serializado (Decimals como string)
  apagadoPor       String?
  restauradoEm     DateTime?
  restauradoComoId String?
  createdAt        DateTime  @default(now())

  @@index([empresaId, tipo])
  @@index([createdAt])
  @@index([numero])
}

// ═══ Módulo Fiscal (camada oficial, ISOLADA do gerencial) ════════════════════
// PRD: docs/fiscal-prd.md. A NF não movimenta estoque, não gera título e não
// lança na contabilidade gerencial. Vínculos com pedidos/minutas são MANUAIS e
// informativos. Impostos calculados automaticamente A PARTIR da NF (motor de
// RegraTributacao), tudo revisável antes de transmitir.

enum ModeloDocFiscal {
  NFE
  NFCE
  NFSE
  CTE
  MDFE
}

enum StatusNotaFiscal {
  EM_DIGITACAO // rascunho editável
  ENVIANDO // número reservado, aguardando provedor (webhook/poll)
  AUTORIZADA
  REJEITADA // corrige e reenvia com o MESMO número
  DENEGADA // número queimado (destinatário irregular)
  CANCELADA
  ERRO // falha de comunicação — retry pelo cron
}

// Configuração fiscal 1:1 com a Empresa (não poluir o model Empresa).
// Tokens são secrets — NUNCA voltam no GET (mascarados, padrão IntegracaoPagamento).
model EmpresaFiscal {
  id                     String    @id @default(cuid())
  empresaId              String    @unique @default("emp_tramontin")
  crt                    Int       @default(3) // 1 Simples | 2 Simples excesso | 3 Regime Normal | 4 MEI
  regimeApuracao         String? // LUCRO_REAL | LUCRO_PRESUMIDO | SIMPLES (informativo)
  cnaePrincipal          String?
  codigoMunicipioIBGE    String? // cMunFG
  provedor               String    @default("FOCUS_NFE")
  ambiente               String    @default("HOMOLOGACAO") // HOMOLOGACAO | PRODUCAO — por empresa
  tokenHomologacao       String? // secret
  tokenProducao          String? // secret
  provedorEmpresaRef     String? // id da empresa no provedor
  cscId                  String? // NFC-e
  cscToken               String? // secret
  certificadoValidade    DateTime? // A1 hospedado no provedor; aqui só metadados
  certificadoStatus      String? // OK | VENCENDO | VENCIDO | AUSENTE
  ultimoNsu              String    @default("0") // cursor da Distribuição DF-e
  manifestacaoAutomatica Boolean   @default(true) // Ciência automática nos resumos
  emiteIbsCbs            Boolean   @default(false) // liga grupos IBS/CBS (NT 2025.002)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  criadoPor              String?
  atualizadoPor          String?
}

// Numeração fiscal NO BANCO (nunca no provedor — estratégia híbrida): reserva
// via UPDATE ... RETURNING na mesma transação que cria a NotaFiscal
// (src/lib/fiscal/numeracao.ts). Séries independentes por ambiente.
model SerieFiscal {
  id            String          @id @default(cuid())
  empresaId     String          @default("emp_tramontin")
  modelo        ModeloDocFiscal
  serie         Int
  ambiente      String // HOMOLOGACAO | PRODUCAO — nunca misturar numeração
  proximoNumero Int             @default(1)
  ativo         Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  criadoPor     String?
  atualizadoPor String?

  @@unique([empresaId, modelo, serie, ambiente])
}

// Documento fiscal emitido por nós (saída; ou entrada emitida por nós, ex.:
// devolução a fornecedor). Destinatário e itens são SNAPSHOT (documento
// imutável); FKs de cliente/pedido são informativas.
model NotaFiscal {
  id                String             @id @default(cuid()) // usado como `ref` idempotente no provedor
  empresaId         String             @default("emp_tramontin")
  modelo            ModeloDocFiscal    @default(NFE)
  serie             Int
  numero            Int
  ambiente          String // gravado na emissão (auditoria)
  tipoOperacao      Int                @default(1) // 0=entrada | 1=saída
  finalidade        Int                @default(1) // 1 normal | 2 complementar | 3 ajuste | 4 devolução
  operacaoFiscalId  String?
  naturezaOperacao  String // texto natOp (snapshot)
  status            StatusNotaFiscal   @default(EM_DIGITACAO)
  chave             String?            @unique // 44 dígitos
  protocolo         String?
  dataEmissao       DateTime           @default(now())
  dataAutorizacao   DateTime?
  codigoRejeicao    String?
  motivoRejeicao    String?
  clienteId         String? // FK informativa
  fornecedorId      String? // devolução de compra
  destSnapshot      Json // nome, cpfCnpj, ie, indIEDest, endereço, cMun — imutável
  vProdutos         Decimal            @default(0) @db.Decimal(15, 2)
  vDesconto         Decimal            @default(0) @db.Decimal(15, 2)
  vFrete            Decimal            @default(0) @db.Decimal(15, 2)
  vSeguro           Decimal            @default(0) @db.Decimal(15, 2)
  vOutro            Decimal            @default(0) @db.Decimal(15, 2)
  vBcIcms           Decimal            @default(0) @db.Decimal(15, 2)
  vIcms             Decimal            @default(0) @db.Decimal(15, 2)
  vIcmsSt           Decimal            @default(0) @db.Decimal(15, 2)
  vIpi              Decimal            @default(0) @db.Decimal(15, 2)
  vPis              Decimal            @default(0) @db.Decimal(15, 2)
  vCofins           Decimal            @default(0) @db.Decimal(15, 2)
  vIbs              Decimal            @default(0) @db.Decimal(15, 2) // NT 2025.002
  vCbs              Decimal            @default(0) @db.Decimal(15, 2) // NT 2025.002
  vTotal            Decimal            @default(0) @db.Decimal(15, 2)
  // Vínculos MANUAIS e informativos ("importar de..." / ação de vincular)
  pedidoVendaId     String?
  minutaId          String?
  devolucaoId       String?
  pedidoCompraId    String? // NF de entrada nossa (devolução de compra)
  chaveReferenciada String? // NFref (devolução/complementar)
  provedorRef       String?
  xmlUrl            String? // @vercel/blob (guarda própria, 5 anos)
  danfeUrl          String? // @vercel/blob
  emailEnviadoEm    DateTime?
  observacoes       String? // infCpl
  itens             NotaFiscalItem[]
  eventos           NotaFiscalEvento[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  criadoPor         String?
  atualizadoPor     String?

  @@unique([empresaId, modelo, serie, numero, ambiente])
  @@index([empresaId, status])
  @@index([pedidoVendaId])
  @@index([clienteId])
  @@index([dataEmissao])
}

model NotaFiscalItem {
  id              String     @id @default(cuid())
  notaFiscalId    String
  ordem           Int // nItem
  itemId          String? // FK informativa
  codigo          String // snapshot
  descricao       String
  ncm             String
  cest            String?
  gtin            String     @default("SEM GTIN")
  cfop            String
  unidade         String
  quantidade      Decimal    @db.Decimal(15, 4)
  vUnitario       Decimal    @db.Decimal(15, 10) // NF-e aceita 10 casas
  vDesconto       Decimal    @default(0) @db.Decimal(15, 2)
  vTotal          Decimal    @db.Decimal(15, 2)
  origem          Int        @default(0)
  cstIcms         String? // CST ou CSOSN conforme CRT da empresa
  aliqIcms        Decimal?   @db.Decimal(7, 4)
  vBcIcms         Decimal?   @db.Decimal(15, 2)
  vIcms           Decimal?   @db.Decimal(15, 2)
  vIcmsSt         Decimal?   @db.Decimal(15, 2)
  cstIpi          String?
  vIpi            Decimal?   @db.Decimal(15, 2)
  cstPis          String?
  vPis            Decimal?   @db.Decimal(15, 2)
  cstCofins       String?
  vCofins         Decimal?   @db.Decimal(15, 2)
  cClassTrib      String? // reforma tributária
  vIbs            Decimal?   @db.Decimal(15, 2)
  vCbs            Decimal?   @db.Decimal(15, 2)
  tributosJson    Json? // detalhe completo (modBC, pRedBC, ST, gIBS/gCBS…)
  regraAplicadaId String? // auditoria: qual RegraTributacao sugeriu
  notaFiscal      NotaFiscal @relation(fields: [notaFiscalId], references: [id], onDelete: Cascade)

  @@index([notaFiscalId])
}

model NotaFiscalEvento {
  id            String     @id @default(cuid())
  notaFiscalId  String
  tipo          String // CANCELAMENTO | CARTA_CORRECAO
  sequencia     Int        @default(1) // CC-e: até 20
  status        String     @default("PENDENTE") // PENDENTE | REGISTRADO | REJEITADO
  justificativa String? // cancelamento (mín. 15 chars)
  correcao      String? // texto da CC-e
  protocolo     String?
  xmlUrl        String?
  dataEvento    DateTime   @default(now())
  criadoPor     String?
  notaFiscal    NotaFiscal @relation(fields: [notaFiscalId], references: [id], onDelete: Cascade)

  @@index([notaFiscalId])
}

model InutilizacaoNumeracao {
  id            String          @id @default(cuid())
  empresaId     String          @default("emp_tramontin")
  modelo        ModeloDocFiscal @default(NFE)
  serie         Int
  numeroInicial Int
  numeroFinal   Int
  justificativa String
  status        String          @default("PENDENTE") // PENDENTE | REGISTRADA | REJEITADA
  protocolo     String?
  xmlUrl        String?
  createdAt     DateTime        @default(now())
  criadoPor     String?
  atualizadoPor String?

  @@index([empresaId])
}

// Inbox do consultor de entrada (Distribuição DF-e + imports manuais).
// Vínculo com pedido de compra é MANUAL — sem conferência, sem estoque.
model DocumentoFiscalRecebido {
  id             String    @id @default(cuid())
  empresaId      String    @default("emp_tramontin") // destinatário (CNPJ da empresa)
  chave          String
  nsu            String?
  tipoDocumento  String // NFE | RESUMO_NFE | EVENTO | CTE
  origem         String    @default("DISTRIBUICAO") // DISTRIBUICAO | IMPORT_XML | IMPORT_CHAVE
  emitenteCnpj   String
  emitenteNome   String
  emitenteUf     String?
  fornecedorId   String? // sugestão por cpfCnpj — confirmação manual
  dataEmissao    DateTime?
  valorTotal     Decimal?  @db.Decimal(15, 2)
  situacaoSefaz  String? // AUTORIZADA | CANCELADA (evento posterior)
  manifestacao   String    @default("PENDENTE") // PENDENTE | CIENCIA | CONFIRMADA | DESCONHECIMENTO | NAO_REALIZADA
  statusVinculo  String    @default("NOVA") // NOVA | VINCULADA | IGNORADA
  xmlCompleto    Boolean   @default(false) // false = só resumo (Ciência libera o XML)
  xmlUrl         String? // blob
  pedidoCompraId String? // vínculo MANUAL
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  criadoPor      String?
  atualizadoPor  String?

  @@unique([empresaId, chave])
  @@index([empresaId, statusVinculo])
  @@index([fornecedorId])
}

// "Gaveta fiscal" do produto (padrão Protheus): agrupa itens com a mesma
// tributação p/ não explodir regras por item. Cadastro COMPARTILHADO (sem empresaId).
model GrupoTributacao {
  id            String            @id @default(cuid())
  codigo        String            @unique
  nome          String // ex.: "Cimento (ST)", "Argamassa", "Revenda geral"
  ativo         Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  criadoPor     String?
  atualizadoPor String?
  itens         Item[]
  regras        RegraTributacao[]
}

// Natureza de operação FISCAL (eixo de saída). Separada do TipoOperacao/TES,
// que segue exclusivo do eixo gerencial de entrada (TES nunca decide destino).
model OperacaoFiscal {
  id            String            @id @default(cuid())
  empresaId     String            @default("emp_tramontin")
  codigo        String // VENDA, DEVOLUCAO_VENDA, REMESSA, TRANSFERENCIA, BONIFICACAO…
  descricao     String // vira natOp da nota
  finalidade    Int               @default(1)
  tipoOperacao  Int               @default(1) // 0=entrada | 1=saída
  ativo         Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  criadoPor     String?
  atualizadoPor String?
  regras        RegraTributacao[]

  @@unique([empresaId, codigo])
}

// Regra do motor de tributação: dimensões anuláveis (null = "qualquer") com
// resolução por pontuação de especificidade — itemId +8, grupo +4, UF +2
// (dentroEstado +1), tipoContribuinte +1; desempate por prioridade. O seed cria
// uma regra geral por empresa/operação; sem regra aplicável a emissão FALHA
// explicitamente (nunca chuta CST). Ver src/lib/fiscal/tributacao.ts.
model RegraTributacao {
  id                String           @id @default(cuid())
  empresaId         String           @default("emp_tramontin") // o regime (CRT) da empresa muda tudo
  operacaoFiscalId  String
  ufDestino         String?
  dentroEstado      Boolean?
  tipoContribuinte  String? // CONTRIBUINTE | ISENTO | NAO_CONTRIBUINTE
  grupoTributacaoId String?
  itemId            String? // exceção pontual (vence o grupo)
  cfop              String
  cstIcms           String // CST (CRT 3) ou CSOSN (CRT 1) — validado contra EmpresaFiscal.crt
  aliqIcms          Decimal?         @db.Decimal(7, 4)
  pRedBcIcms        Decimal?         @db.Decimal(7, 4)
  modBcIcms         Int?             @default(3)
  temSt             Boolean          @default(false)
  mvaSt             Decimal?         @db.Decimal(7, 4)
  cstIpi            String?
  aliqIpi           Decimal?         @db.Decimal(7, 4)
  cstPis            String?
  aliqPis           Decimal?         @db.Decimal(7, 4)
  cstCofins         String?
  aliqCofins        Decimal?         @db.Decimal(7, 4)
  cClassTrib        String? // reforma: classificação tributária IBS/CBS
  cBeneficio        String?
  mensagemFiscal    String? // infAdProd/infCpl (fundamentação legal)
  prioridade        Int              @default(0) // desempate manual
  ativo             Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  criadoPor         String?
  atualizadoPor     String?
  operacaoFiscal    OperacaoFiscal   @relation(fields: [operacaoFiscalId], references: [id])
  grupoTributacao   GrupoTributacao? @relation(fields: [grupoTributacaoId], references: [id])

  @@index([empresaId, operacaoFiscalId])
}

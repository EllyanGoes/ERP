model SupportTicket {
  id              String              @id @default(cuid())
  numero          String              @unique
  titulo          String
  descricao       String
  tipo            TipoSupportTicket   @default(MELHORIA)
  status          StatusSupportTicket @default(ABERTO)
  prioridade      PrioridadeTicket    @default(MEDIA)
  imagemUrl       String?
  imagemNome      String?
  resposta        String?
  usuarioId       String
  respondidoPorId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

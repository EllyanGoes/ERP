// ── Req/Dev de Materiais ──────────────────────────────────────────────────────

model RequisicaoMaterial {
  id             String                   @id @default(cuid())
  numero         String                   @unique
  tipo           TipoRequisicaoMaterial   @default(REQUISICAO)
  status         StatusRequisicaoMaterial @default(RASCUNHO)
  localEstoqueId String
  colaboradorId  String?
  setorId        String?
  almoxarifeId   String?
  os             String?
  centroCustoId  String?
  contaContabil  String?
  data           DateTime                 @default(now())
  observacoes    String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  localEstoque   LocalEstoque             @relation(fields: [localEstoqueId], references: [id])
  colaborador    Colaborador?             @relation("RM_Solicitante", fields: [colaboradorId], references: [id])
  setor          Setor?                   @relation(fields: [setorId], references: [id])
  almoxarife     Colaborador?             @relation("RM_Almoxarife", fields: [almoxarifeId], references: [id])
  centroCusto    CentroCusto?             @relation(fields: [centroCustoId], references: [id])
  itens          RequisicaoMaterialItem[]

  @@index([status])
  @@index([localEstoqueId])
}

model RequisicaoMaterialItem {
  id            String             @id @default(cuid())
  requisicaoId  String
  itemId        String
  quantidade    Decimal            @db.Decimal(15, 3)
  unidade       String?
  localizacao   String?
  centroCustoId String?
  contaContabil String?
  os            String?
  requisicaoRef String?
  requisicao    RequisicaoMaterial @relation(fields: [requisicaoId], references: [id], onDelete: Cascade)
  item          Item               @relation(fields: [itemId], references: [id])
  centroCusto   CentroCusto?       @relation(fields: [centroCustoId], references: [id])

  @@index([requisicaoId])
}

// ── Inventário de Materiais ───────────────────────────────────────────────────

model InventarioMaterial {
  id             String                   @id @default(cuid())
  numero         String                   @unique
  localEstoqueId String
  colaboradorId  String?
  data           DateTime
  tipo           TipoInventarioMaterial   @default(TOTAL)
  status         StatusInventarioMaterial @default(RASCUNHO)
  observacoes    String?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  localEstoque   LocalEstoque             @relation(fields: [localEstoqueId], references: [id])
  colaborador    Colaborador?             @relation(fields: [colaboradorId], references: [id])
  itens          InventarioMaterialItem[]

  @@index([status])
  @@index([localEstoqueId])
}

model InventarioMaterialItem {
  id           String             @id @default(cuid())
  inventarioId String
  itemId       String
  localizacao  String?
  saldoSistema Decimal            @db.Decimal(15, 3)
  saldoFisico  Decimal?           @db.Decimal(15, 3)
  diferenca    Decimal?           @db.Decimal(15, 3)
  inventario   InventarioMaterial @relation(fields: [inventarioId], references: [id], onDelete: Cascade)
  item         Item               @relation(fields: [itemId], references: [id])

  @@index([inventarioId])
}

enum TipoRequisicaoMaterial {
  REQUISICAO
  DEVOLUCAO
}

enum StatusRequisicaoMaterial {
  RASCUNHO
  ABERTA
  ATENDIDA
  CANCELADA
}

enum TipoInventarioMaterial {
  TOTAL
  PARCIAL
  CICLICO
}

enum StatusInventarioMaterial {
  RASCUNHO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

model SupportTicket {
  id              String              @id @default(cuid())
  numero          String              @unique
  titulo          String
  descricao       String
  tipo            TipoSupportTicket   @default(MELHORIA)
  status          StatusSupportTicket @default(ABERTO)
  prioridade      PrioridadeTicket    @default(MEDIA)
  imagemUrl       String?
  imagemNome      String?
  resposta        String?
  usuarioId       String
  respondidoPorId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
  usuario         Usuario             @relation("TicketsAbertos", fields: [usuarioId], references: [id])
  respondidoPor   Usuario?            @relation("TicketsRespondidos", fields: [respondidoPorId], references: [id])

  @@index([usuarioId])
  @@index([status])
}

enum TipoSupportTicket {
  MELHORIA
  BUG
  DUVIDA
}

enum StatusSupportTicket {
  ABERTO
  EM_ANALISE
  RESOLVIDO
  FECHADO
}

enum PrioridadeTicket {
  BAIXA
  MEDIA
  ALTA
  CRITICA
}

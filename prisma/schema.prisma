generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model AnexoCotacaoFornecedor {
  id                  String            @id
  cotacaoFornecedorId String
  nome                String
  url                 String
  tamanho             Int
  tipo                String
  createdAt           DateTime          @default(now())
  cotacaoFornecedor   CotacaoFornecedor @relation(fields: [cotacaoFornecedorId], references: [id], onDelete: Cascade)
}

model AprovacaoEtapa {
  id             String         @id
  fluxoId        String
  ordem          Int
  nome           String?
  valorMin       Decimal?       @db.Decimal(15, 2)
  valorMax       Decimal?       @db.Decimal(15, 2)
  aprovadorId    String?
  createdAt      DateTime       @default(now())
  colaboradorId  String?
  aprovador      Usuario?       @relation(fields: [aprovadorId], references: [id])
  colaborador    Colaborador?   @relation(fields: [colaboradorId], references: [id])
  fluxo          AprovacaoFluxo @relation(fields: [fluxoId], references: [id], onDelete: Cascade)
}

model AprovacaoFluxo {
  id             String            @id
  nome           String
  ativo          Boolean           @default(true)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime
  processo       ProcessoAprovacao @default(SOLICITACAO_COMPRAS)
  etapas         AprovacaoEtapa[]
  aprovacoesSC   AprovacaoSC[]
}

model AprovacaoSC {
  id                String            @id
  necessidadeId     String
  etapaOrdem        Int
  etapaNome         String?
  aprovadorId       String
  status            StatusAprovacao   @default(PENDENTE)
  observacao        String?
  respondidoEm      DateTime?
  waMsgId           String?
  createdAt         DateTime          @default(now())
  fluxoId           String?
  aprovador         Usuario           @relation(fields: [aprovadorId], references: [id])
  fluxo             AprovacaoFluxo?   @relation(fields: [fluxoId], references: [id])
  necessidade       NecessidadeCompra @relation(fields: [necessidadeId], references: [id], onDelete: Cascade)
}

model CentroCusto {
  id                 String              @id
  codigo             String              @unique
  nome               String
  grupoCentroCustoId String?
  ativo              Boolean             @default(true)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime
  grupoCentroCusto   GrupoCentroCusto?   @relation(fields: [grupoCentroCustoId], references: [id])
  necessidadesCompra NecessidadeCompra[]

  @@index([grupoCentroCustoId])
}

model Cliente {
  id           String         @id
  tipoPessoa   TipoPessoa     @default(JURIDICA)
  razaoSocial  String
  nomeFantasia String?
  cpfCnpj      String         @unique
  ie           String?
  email        String?
  telefone     String?
  celular      String?
  status       StatusCliente  @default(ATIVO)
  observacoes  String?
  cep          String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  estado       String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime
  contasReceber ContaReceber[]
  pedidosVenda  PedidoVenda[]

  @@index([cpfCnpj])
  @@index([status])
}

model Colaborador {
  id             String           @id
  nome           String
  cpf            String?          @unique
  rg             String?
  email          String?
  telefone       String?
  cargo          String?
  departamento   String?
  dataAdmissao   DateTime?
  dataDemissao   DateTime?
  usuarioId      String?          @unique
  ativo          Boolean          @default(true)
  observacoes    String?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  etapasAprovacao AprovacaoEtapa[]
  usuario         Usuario?         @relation(fields: [usuarioId], references: [id])
  filiais         Filial[]
}

model CondicaoPagamento {
  id                String   @id
  nome              String
  descricao         String?
  numeroParcelas    Int      @default(1)
  prazoInicial      Int      @default(0)
  intervaloParcelas Int      @default(30)
  descontoVista     Decimal? @db.Decimal(5, 2)
  ativo             Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime
}

model ConferenciaCompra {
  id                    String                  @id
  numero                String                  @unique
  pedidoId              String                  @unique
  status                StatusConferenciaCompra @default(PENDENTE)
  dataConferencia       DateTime?
  responsavel           String?
  observacoes           String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  pedido                PedidoCompra            @relation(fields: [pedidoId], references: [id])
  itens                 ConferenciaCompraItem[]

  @@index([status])
}

model ConferenciaCompraItem {
  id                  String                @id
  conferenciaId       String
  itemId              String
  quantidadePedida    Decimal               @db.Decimal(15, 3)
  quantidadeRecebida  Decimal               @default(0) @db.Decimal(15, 3)
  divergencia         Boolean               @default(false)
  observacao          String?
  conferencia         ConferenciaCompra     @relation(fields: [conferenciaId], references: [id], onDelete: Cascade)
  item                Item                  @relation(fields: [itemId], references: [id])
  movimentacoes       MovimentacaoEstoque[]
}

model Configuracao {
  chave     String   @id
  valor     String?
  updatedAt DateTime
}

model ContaPagar {
  id              String            @id
  numero          String            @unique
  fornecedorId    String?
  descricao       String
  categoria       String?
  valorOriginal   Decimal           @db.Decimal(15, 2)
  valorPago       Decimal           @default(0) @db.Decimal(15, 2)
  valorMulta      Decimal           @default(0) @db.Decimal(15, 2)
  valorJuros      Decimal           @default(0) @db.Decimal(15, 2)
  dataVencimento  DateTime
  dataPagamento   DateTime?
  status          StatusConta       @default(ABERTA)
  formaPagamento  String?
  notaFiscal      String?
  observacoes     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  fornecedor      Fornecedor?       @relation(fields: [fornecedorId], references: [id])
  lancamentos     LancamentoCaixa[]

  @@index([dataVencimento])
  @@index([fornecedorId])
  @@index([status])
}

model ContaReceber {
  id              String            @id
  numero          String            @unique
  clienteId       String
  pedidoVendaId   String?
  descricao       String
  valorOriginal   Decimal           @db.Decimal(15, 2)
  valorPago       Decimal           @default(0) @db.Decimal(15, 2)
  valorMulta      Decimal           @default(0) @db.Decimal(15, 2)
  valorJuros      Decimal           @default(0) @db.Decimal(15, 2)
  dataVencimento  DateTime
  dataPagamento   DateTime?
  status          StatusConta       @default(ABERTA)
  formaPagamento  String?
  nossoNumero     String?
  observacoes     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  cliente         Cliente           @relation(fields: [clienteId], references: [id])
  pedidoVenda     PedidoVenda?      @relation(fields: [pedidoVendaId], references: [id])
  lancamentos     LancamentoCaixa[]

  @@index([clienteId])
  @@index([dataVencimento])
  @@index([status])
}

model CotacaoCompra {
  id                   String              @id
  numero               String              @unique
  necessidadeId        String?
  status               StatusCotacaoCompra @default(PENDENTE)
  dataLimiteResposta   DateTime?
  observacoes          String?
  aprovadoPor          String?
  dataAprovacao        DateTime?
  fornecedorVencedorId String?
  motivoReprovacao     String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime
  infoEntrega          String?
  nome                 String?
  necessidade          NecessidadeCompra?  @relation(fields: [necessidadeId], references: [id])
  fornecedores         CotacaoFornecedor[]
  pedidos              PedidoCompra[]

  @@index([status])
}

model CotacaoFornecedor {
  id                         String                       @id
  cotacaoId                  String
  fornecedorId               String
  status                     StatusRespostaFornecedor     @default(AGUARDANDO)
  prazoEntregaDias           Int?
  condicoesPagamento         String?
  observacao                 String?
  totalCalculado             Decimal?                     @db.Decimal(15, 2)
  melhorOpcao                Boolean                      @default(false)
  createdAt                  DateTime                     @default(now())
  updatedAt                  DateTime
  desconto                   Decimal?                     @db.Decimal(5, 2)
  despesas                   Decimal?                     @db.Decimal(15, 2)
  frete                      Decimal?                     @db.Decimal(15, 2)
  seguro                     Decimal?                     @db.Decimal(15, 2)
  tipoFrete                  String?
  vrDesconto                 Decimal?                     @db.Decimal(15, 2)
  AnexoCotacaoFornecedor     AnexoCotacaoFornecedor[]
  cotacao                    CotacaoCompra                @relation(fields: [cotacaoId], references: [id], onDelete: Cascade)
  fornecedor                 Fornecedor                   @relation(fields: [fornecedorId], references: [id])
  historico                  CotacaoFornecedorHistorico[]
  itens                      CotacaoFornecedorItem[]

  @@unique([cotacaoId, fornecedorId])
}

model CotacaoFornecedorHistorico {
  id                  String            @id
  cotacaoFornecedorId String
  versao              Int               @default(1)
  totalCalculado      Decimal?          @db.Decimal(15, 2)
  frete               Decimal?          @db.Decimal(15, 2)
  tipoFrete           String?
  desconto            Decimal?          @db.Decimal(5, 2)
  vrDesconto          Decimal?          @db.Decimal(15, 2)
  despesas            Decimal?          @db.Decimal(15, 2)
  seguro              Decimal?          @db.Decimal(15, 2)
  condicoesPagamento  String?
  prazoEntregaDias    Int?
  observacao          String?
  itensSnapshot       Json?
  createdAt           DateTime          @default(now())
  cotacaoFornecedor   CotacaoFornecedor @relation(fields: [cotacaoFornecedorId], references: [id], onDelete: Cascade)

  @@index([cotacaoFornecedorId])
}

model CotacaoFornecedorItem {
  id                  String            @id
  cotacaoFornecedorId String
  itemId              String
  quantidade          Decimal           @db.Decimal(15, 3)
  precoUnitario       Decimal?          @db.Decimal(15, 2)
  subtotal            Decimal?          @db.Decimal(15, 2)
  disponivel          Boolean           @default(true)
  qtdDisponivel       Decimal?          @db.Decimal(15, 3)
  situacao            String?           @default("CONSIDERA")
  cotacaoFornecedor   CotacaoFornecedor @relation(fields: [cotacaoFornecedorId], references: [id], onDelete: Cascade)
  item                Item              @relation(fields: [itemId], references: [id])
}

model Empresa {
  id           String   @id
  razaoSocial  String
  nomeFantasia String?
  cnpj         String   @unique
  ie           String?
  im           String?
  email        String?
  telefone     String?
  cep          String?
  logradouro   String?
  numero       String?
  complemento  String?
  bairro       String?
  cidade       String?
  estado       String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}

model EnderecoEstoque {
  id             String       @id
  localEstoqueId String
  codigo         String
  descricao      String?
  ativo          Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  localEstoque   LocalEstoque @relation(fields: [localEstoqueId], references: [id], onDelete: Cascade)

  @@unique([localEstoqueId, codigo])
}

model EstoqueItem {
  id              String        @id
  itemId          String
  quantidadeAtual Decimal       @default(0) @db.Decimal(15, 3)
  quantidadeMin   Decimal       @default(0) @db.Decimal(15, 3)
  quantidadeMax   Decimal?      @db.Decimal(15, 3)
  localizacao     String?
  updatedAt       DateTime
  localEstoqueId  String?
  item            Item          @relation(fields: [itemId], references: [id])
  localEstoque    LocalEstoque? @relation(fields: [localEstoqueId], references: [id])

  @@unique([itemId, localEstoqueId])
  @@index([itemId])
}

model Filial {
  id                String              @id
  razaoSocial       String
  nomeFantasia      String?
  cnpj              String?             @unique
  ie                String?
  email             String?
  telefone          String?
  celular           String?
  cep               String?
  logradouro        String?
  numero            String?
  complemento       String?
  bairro            String?
  cidade            String?
  estado            String?
  ativo             Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  locaisEstoque     LocalEstoque[]
  necessidadesCompra NecessidadeCompra[]
  colaboradores     Colaborador[]
}

model FormaPagamento {
  id        String             @id
  nome      String
  tipo      TipoFormaPagamento @default(OUTROS)
  descricao String?
  ativo     Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime
}

model Fornecedor {
  id                String              @id
  tipoPessoa        TipoPessoa          @default(JURIDICA)
  razaoSocial       String
  nomeFantasia      String?
  cpfCnpj           String?             @unique
  ie                String?
  email             String?
  telefone          String?
  cep               String?
  logradouro        String?
  numero            String?
  complemento       String?
  bairro            String?
  cidade            String?
  estado            String?
  ativo             Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  celular           String?
  contato           String?
  observacoes       String?
  contasPagar       ContaPagar[]
  cotacoes          CotacaoFornecedor[]
  contatos          FornecedorContato[]
  pedidosCompra     PedidoCompra[]
  produtos          ProdutoFornecedor[]
}

model FornecedorContato {
  id           String     @id
  fornecedorId String
  nome         String
  cargo        String?
  telefone     String?
  ramal        String?
  email        String?
  principal    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  fornecedor   Fornecedor @relation(fields: [fornecedorId], references: [id], onDelete: Cascade)
}

model GrupoCentroCusto {
  id          String        @id
  nome        String        @unique
  ativo       Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime
  centros CentroCusto[]
}

model Item {
  id                    String                  @id
  codigo                String                  @unique
  descricao             String
  tipo                  TipoItem                @default(PRODUTO)
  unidadeMedida         UnidadeMedida           @default(UN)
  ncm                   String?
  cest                  String?
  precoVenda            Decimal                 @db.Decimal(15, 2)
  precoCusto            Decimal?                @db.Decimal(15, 2)
  pesoLiquido           Decimal?                @db.Decimal(10, 3)
  pesoBruto             Decimal?                @db.Decimal(10, 3)
  ativo                 Boolean                 @default(true)
  observacoes           String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  tipoProdutoId         String?
  unidadeId             String?
  conferenciaCompraItens ConferenciaCompraItem[]
  cotacaoFornecedorItens CotacaoFornecedorItem[]
  estoqueItens           EstoqueItem[]
  tipoProduto            TipoProduto?            @relation(fields: [tipoProdutoId], references: [id])
  unidade                Unidade?                @relation(fields: [unidadeId], references: [id])
  itemUnidades           ItemUnidade[]
  movimentacoes          MovimentacaoEstoque[]
  necessidadeCompraItens NecessidadeCompraItem[]
  pedidoCompraItens      PedidoCompraItem[]
  pedidoVendaItens       PedidoVendaItem[]
  produtosFornecedor     ProdutoFornecedor[]

  @@index([codigo])
  @@index([tipo])
}

model ItemUnidade {
  id                                         String   @id
  itemId                                     String
  unidadeId                                  String
  fatorConversao                             Decimal? @db.Decimal(15, 6)
  isPrincipal                                Boolean  @default(false)
  createdAt                                  DateTime @default(now())
  baseUnidadeId                              String?
  baseUnidade Unidade? @relation("ItemUnidade_baseUnidadeIdToUnidade", fields: [baseUnidadeId], references: [id])
  item        Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  unidade     Unidade  @relation("ItemUnidade_unidadeIdToUnidade", fields: [unidadeId], references: [id])

  @@unique([itemId, unidadeId])
  @@index([itemId])
}

model LancamentoCaixa {
  id             String              @id
  tipo           TipoLancamentoCaixa
  descricao      String
  valor          Decimal             @db.Decimal(15, 2)
  dataLancamento DateTime
  contaReceberId String?
  contaPagarId   String?
  observacoes    String?
  createdAt      DateTime            @default(now())
  contaPagar     ContaPagar?         @relation(fields: [contaPagarId], references: [id])
  contaReceber   ContaReceber?       @relation(fields: [contaReceberId], references: [id])

  @@index([dataLancamento])
  @@index([tipo])
}

model LocalEstoque {
  id                  String                @id
  nome                String
  descricao           String?
  ativo               Boolean               @default(true)
  createdAt           DateTime              @default(now())
  updatedAt           DateTime
  filialId            String?
  enderecos          EnderecoEstoque[]
  estoqueItens       EstoqueItem[]
  filial             Filial?               @relation(fields: [filialId], references: [id])
  movimentacoes      MovimentacaoEstoque[]
  necessidadesCompra NecessidadeCompra[]
}

model LoteMovimentacao {
  id                  String                  @id
  numero              String                  @unique
  tipo                TipoMovimentacaoEstoque
  documento           String?
  observacoes         String?
  createdAt           DateTime                @default(now())
  itens MovimentacaoEstoque[]
}

model MovimentacaoEstoque {
  id                    String                  @id
  itemId                String
  tipo                  TipoMovimentacaoEstoque
  quantidade            Decimal                 @db.Decimal(15, 3)
  saldoAntes            Decimal                 @db.Decimal(15, 3)
  saldoDepois           Decimal                 @db.Decimal(15, 3)
  documento             String?
  observacoes           String?
  criadoPor             String?
  pedidoVendaItemId     String?
  createdAt             DateTime                @default(now())
  conferenciaItemId     String?
  localEstoqueId        String?
  loteId                String?
  valorUnitario         Decimal?                @db.Decimal(15, 4)
  unidadeId             String?
  conferenciaItem ConferenciaCompraItem?  @relation(fields: [conferenciaItemId], references: [id])
  item            Item                    @relation(fields: [itemId], references: [id])
  localEstoque    LocalEstoque?           @relation(fields: [localEstoqueId], references: [id])
  lote            LoteMovimentacao?       @relation(fields: [loteId], references: [id])
  pedidoVendaItem PedidoVendaItem?        @relation(fields: [pedidoVendaItemId], references: [id])
  unidade         Unidade?                @relation(fields: [unidadeId], references: [id])

  @@index([createdAt])
  @@index([itemId])
  @@index([loteId])
  @@index([tipo])
}

model NecessidadeCompra {
  id                    String                  @id
  numero                String                  @unique
  status                StatusNecessidade       @default(RASCUNHO)
  solicitante           String?
  justificativa         String?
  dataNecessidade       DateTime?
  observacoes           String?
  aprovadoPor           String?
  dataAprovacao         DateTime?
  motivoReprovacao      String?
  createdAt             DateTime                @default(now())
  updatedAt             DateTime
  categoria             String?
  centroCustoId         String?
  classificacaoAuxiliar String?
  filialId              String?
  localEstoqueId        String?
  motivo                String?
  prioridade            Int                     @default(3)
  projeto               String?
  tipoCompra            String?
  aprovacoes            AprovacaoSC[]
  cotacoes              CotacaoCompra[]
  centroCusto           CentroCusto?            @relation(fields: [centroCustoId], references: [id])
  filial                Filial?                 @relation(fields: [filialId], references: [id])
  localEstoque          LocalEstoque?           @relation(fields: [localEstoqueId], references: [id])
  itens                 NecessidadeCompraItem[]

  @@index([status])
}

model NecessidadeCompraItem {
  id                 String            @id
  necessidadeId      String
  itemId             String
  quantidade         Decimal           @db.Decimal(15, 3)
  quantidadeAprovada Decimal?          @db.Decimal(15, 3)
  observacao         String?
  unidade            String?
  item               Item              @relation(fields: [itemId], references: [id])
  necessidade        NecessidadeCompra @relation(fields: [necessidadeId], references: [id], onDelete: Cascade)
}

model PedidoCompra {
  id                  String             @id
  numero              String             @unique
  cotacaoId           String?
  fornecedorId        String
  status              StatusPedidoCompra @default(RASCUNHO)
  valorTotal          Decimal            @default(0) @db.Decimal(15, 2)
  dataEntregaPrevista DateTime?
  observacoes         String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime
  condicoesPagamento  String?
  contato             String?
  desconto            Decimal?           @db.Decimal(5, 2)
  despesas            Decimal?           @db.Decimal(15, 2)
  email               String?
  frete               Decimal?           @db.Decimal(15, 2)
  seguro              Decimal?           @db.Decimal(15, 2)
  tipoFrete           String?
  vrDesconto          Decimal?           @db.Decimal(15, 2)
  conferencia         ConferenciaCompra?
  cotacao             CotacaoCompra?     @relation(fields: [cotacaoId], references: [id])
  fornecedor          Fornecedor         @relation(fields: [fornecedorId], references: [id])
  itens               PedidoCompraItem[]

  @@index([fornecedorId])
  @@index([status])
}

model PedidoCompraItem {
  id            String       @id
  pedidoId      String
  itemId        String
  quantidade    Decimal      @db.Decimal(15, 3)
  precoUnitario Decimal      @db.Decimal(15, 2)
  valorTotal    Decimal      @db.Decimal(15, 2)
  item          Item         @relation(fields: [itemId], references: [id])
  pedido        PedidoCompra @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
}

model PedidoVenda {
  id                String            @id
  numero            String            @unique
  clienteId         String
  status            StatusPedidoVenda @default(ORCAMENTO)
  dataEmissao       DateTime          @default(now())
  dataEntrega       DateTime?
  valorProdutos     Decimal           @default(0) @db.Decimal(15, 2)
  valorDesconto     Decimal           @default(0) @db.Decimal(15, 2)
  valorFrete        Decimal           @default(0) @db.Decimal(15, 2)
  valorTotal        Decimal           @default(0) @db.Decimal(15, 2)
  condicaoPagamento String?
  observacoes       String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  contasReceber     ContaReceber[]
  cliente           Cliente           @relation(fields: [clienteId], references: [id])
  itens             PedidoVendaItem[]

  @@index([clienteId])
  @@index([dataEmissao])
  @@index([status])
}

model PedidoVendaItem {
  id                  String                @id
  pedidoVendaId       String
  itemId              String
  quantidade          Decimal               @db.Decimal(15, 3)
  precoUnitario       Decimal               @db.Decimal(15, 2)
  desconto            Decimal               @default(0) @db.Decimal(15, 2)
  valorTotal          Decimal               @db.Decimal(15, 2)
  movimentacoes MovimentacaoEstoque[]
  item          Item                  @relation(fields: [itemId], references: [id])
  pedidoVenda   PedidoVenda           @relation(fields: [pedidoVendaId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([pedidoVendaId])
}

model PerfilAcesso {
  id         String    @id
  nome       String    @unique
  descricao  String?
  permissoes String[]
  createdAt  DateTime  @default(now())
  updatedAt  DateTime
  usuarios   Usuario[]
}

model Permissao {
  id        String  @id
  usuarioId String
  modulo    String
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, modulo])
  @@index([usuarioId])
}

model ProdutoFornecedor {
  id                String     @id
  itemId            String
  fornecedorId      String
  codigoFornecedor  String?
  precoUltimo       Decimal?   @db.Decimal(15, 2)
  prazoEntregaDias  Int?
  ativo             Boolean    @default(true)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime
  classificacao     String?
  dataUltimaCompra  DateTime?
  especificacao     String?
  indiceFinanceiro  String?
  percentual        Decimal?   @db.Decimal(5, 2)
  qtdeUltimaCompra  Decimal?   @db.Decimal(15, 3)
  tempoResuprimento Int?
  ultimaQtdeDev     Decimal?   @db.Decimal(15, 3)
  unidade           String?
  fornecedor        Fornecedor @relation(fields: [fornecedorId], references: [id])
  item              Item       @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([itemId, fornecedorId])
}

model Sequencia {
  prefixo String @id
  ultimo  Int    @default(0)
}

model TipoProduto {
  id        String   @id
  nome      String
  descricao String?
  ativo     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime
  itens     Item[]
}

model Unidade {
  id                                                          String                @id
  nome                                                        String
  sigla                                                       String                @unique
  ativo                                                       Boolean               @default(true)
  createdAt                                                   DateTime              @default(now())
  updatedAt                                                   DateTime
  itens               Item[]
  itemUnidadesBase    ItemUnidade[]         @relation("ItemUnidade_baseUnidadeIdToUnidade")
  itemUnidades        ItemUnidade[]         @relation("ItemUnidade_unidadeIdToUnidade")
  movimentacoes       MovimentacaoEstoque[]
  conversoesDestino   UnidadeConversao[]    @relation("UnidadeConversao_unidadeDestinoIdToUnidade")
  conversoesOrigem    UnidadeConversao[]    @relation("UnidadeConversao_unidadeOrigemIdToUnidade")
}

model UnidadeConversao {
  id                                                 String   @id
  unidadeOrigemId                                    String
  unidadeDestinoId                                   String
  fator                                              Decimal  @db.Decimal(18, 6)
  createdAt                                          DateTime @default(now())
  updatedAt                                          DateTime
  unidadeDestino Unidade  @relation("UnidadeConversao_unidadeDestinoIdToUnidade", fields: [unidadeDestinoId], references: [id], onDelete: Cascade)
  unidadeOrigem  Unidade  @relation("UnidadeConversao_unidadeOrigemIdToUnidade", fields: [unidadeOrigemId], references: [id], onDelete: Cascade)

  @@unique([unidadeOrigemId, unidadeDestinoId])
}

model Usuario {
  id             String           @id
  nome           String
  email          String           @unique
  senha          String
  perfil         PerfilUsuario    @default(USUARIO)
  ativo          Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  perfilAcessoId String?
  telefone       String?
  aprovacaoEtapas AprovacaoEtapa[]
  aprovacoesSC    AprovacaoSC[]
  colaborador     Colaborador?
  permissoes      Permissao[]
  perfilAcesso    PerfilAcesso?    @relation(fields: [perfilAcessoId], references: [id])
}


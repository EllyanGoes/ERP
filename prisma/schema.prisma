// Destino contábil do consumo de uma requisição (vem das flags do item + centro;
// a natureza é gaveta gerencial e NÃO define o destino). Ver src/lib/pcp/rotear-requisicao.ts.
enum DestinoConsumo {
  PEP_MD
  IMOBILIZADO
  CIF
  DESPESA
}

model Item {
  id                     String                   @id @default(cuid())
  codigo                 String                   @unique
  descricao              String
  tipo                   TipoItem                 @default(PRODUTO)
  unidadeMedida          UnidadeMedida            @default(UN)
  ncm                    String?
  cest                   String?
  precoVenda             Decimal                  @db.Decimal(15, 2)
  precoVendaMedio        Decimal?                 @db.Decimal(15, 2) // média ponderada das vendas reais (base de valoração do acabado enquanto não há custo de produção)
  precoCusto             Decimal?                 @db.Decimal(15, 2)
  pesoLiquido            Decimal?                 @db.Decimal(10, 3)
  pesoBruto              Decimal?                 @db.Decimal(10, 3)
  ativo                  Boolean                  @default(true)
  favorito               Boolean                  @default(false)
  vendavel               Boolean                  @default(false)
  comodato               Boolean                  @default(false)
  // Item consumível (baixa no consumo) vs. permanente (ferramentas: requisitadas
  // e devolvidas ao almoxarifado, sem baixa de estoque no uso).
  consumivel             Boolean                  @default(true)
  // Insumo que compõe custo/saldo de produção. false = ignorado no PCP (ex.: água).
  compoeCusto            Boolean                  @default(true)
  // Consumível INDIRETO de fábrica (peça de manutenção, lubrificante, refratário,
  // EPI, solda). Quando true, a requisição roteia para CIF se o centro de custo for
  // fabril (senão Despesa). Não usado por material direto (MATERIA_PRIMA/INSUMO/EMBALAGEM
  // com compoeCusto), que vai sempre para o PEP-MD. Ver src/lib/pcp/rotear-requisicao.ts.
  fabril                 Boolean                  @default(false)
  // Item que CAPITALIZA (vai ao Imobilizado, não vira custo/despesa do mês):
  // ferramental permanente de alto valor; material de obra/ampliação/benfeitoria
  // (CPC 27). A requisição roteia para "Imobilizado em Andamento" (1.2.4), com
  // precedência sobre `fabril`. Ver src/lib/pcp/rotear-requisicao.ts.
  capitaliza             Boolean                  @default(false)
  // Natureza financeira-padrão (gaveta gerencial sugerida): pré-preenche a linha da
  // requisição. NÃO define o destino contábil (isso vem das flags + centro).
  naturezaPadraoId       String?
  naturezaPadrao         NaturezaFinanceira?      @relation("ItemNaturezaPadrao", fields: [naturezaPadraoId], references: [id])
  estoqueMinimo          Decimal?                 @db.Decimal(15, 3)
  estoqueMaximo          Decimal?                 @db.Decimal(15, 3)
  pontoReposicao         Decimal?                 @db.Decimal(15, 3)
  leadTimeDias           Int?
  observacoes            String?
  createdAt              DateTime                 @default(now())
  updatedAt              DateTime                 @updatedAt
  tipoProdutoId          String?
  // Natureza de armazenagem — valida em que locais o produto pode entrar.
  categoriaEstoque       CategoriaEstoque?
  // Estados WIP que o produto atende (códigos de EstadoWip) — só p/ PA/WIP.
  estadosWip             String[]                 @default([])
  unidadeId              String?
  conferenciaCompraItens ConferenciaCompraItem[]
  cotacaoFornecedorItens CotacaoFornecedorItem[]
  estoqueItems           EstoqueItem[]
  tipoProduto            TipoProduto?             @relation(fields: [tipoProdutoId], references: [id])
  unidade                Unidade?                 @relation(fields: [unidadeId], references: [id])
  itemUnidades           ItemUnidade[]
  cargasVeiculo          ItemCargaVeiculo[]
  movimentacoes          MovimentacaoEstoque[]
  movimentacoesComodato  MovimentacaoComodato[]
  necessidadeCompraItens NecessidadeCompraItem[]
  pedidoCompraItens      PedidoCompraItem[]
  pedidoVendaItens       PedidoVendaItem[]
  minutaItens            MinutaItem[]
  produtosFornecedor     ProdutoFornecedor[]
  itensRequisicao        RequisicaoMaterialItem[]
  itensInventario        InventarioMaterialItem[]
  tabelaPrecoItens       TabelaPrecoItem[]
  fluxosProducao         FluxoProducao[]
  ordensProducao         OrdemProducao[]
  ordemProducaoProdutoItens OrdemProducaoProdutoItem[] @relation("OrdemProducaoProdutoItem_item")
  engenhariaProduto      EngenhariaProduto?       @relation("EngenhariaProdutoItem")
  insumosEngenharia      EngenhariaInsumo[]       @relation("EngenhariaInsumoItem")
  // Item de SEGUNDA qualidade: mesma engenharia/custo do produto base; muda só o
  // preço de venda. O custeio usa a engenharia do base quando a segunda não tem.
  produtoBaseId          String?
  produtoBase            Item?                    @relation("ProdutoSegunda", fields: [produtoBaseId], references: [id])
  segundas               Item[]                   @relation("ProdutoSegunda")
  planosMestre           PlanoMestre[]
  metasProducaoDiaria    MetaProducaoDiaria[]
  custosEmpresa          ItemCustoEmpresa[]
  concorrentePrecos      ConcorrentePreco[]

  @@index([codigo])
  @@index([tipo])
}

// Custo médio (CMPM) por empresa do grupo: o cadastro do produto é
// compartilhado, mas cada empresa tem o próprio custo (fabricação numa,
// compra noutra). Item.precoCusto segue como CMPM global/legado (fallback).
model ItemCustoEmpresa {
  id         String   @id @default(cuid())
  empresaId  String
  itemId     String
  precoCusto Decimal? @db.Decimal(15, 2)
  updatedAt  DateTime @updatedAt
  item       Item     @relation(fields: [itemId], references: [id])
  empresa    Empresa  @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, itemId])
  @@index([itemId])
}

model ItemUnidade {
  id             String   @id @default(cuid())
  itemId         String
  unidadeId      String
  fatorConversao Decimal? @db.Decimal(18, 9)
  isPrincipal    Boolean  @default(false)
  createdAt      DateTime @default(now())
  baseUnidadeId  String?
  baseUnidade    Unidade? @relation("ItemUnidade_baseUnidadeIdToUnidade", fields: [baseUnidadeId], references: [id])
  item           Item     @relation(fields: [itemId], references: [id], onDelete: Cascade)
  unidade        Unidade  @relation("ItemUnidade_unidadeIdToUnidade", fields: [unidadeId], references: [id])

  @@unique([itemId, unidadeId])
  @@index([itemId])
}

model LancamentoFinanceiro {
  id                    String                @id @default(cuid())
  empresaId             String                @default("emp_tramontin")
  tipo                  TipoLancamentoCaixa
  descricao             String
  valor                 Decimal               @db.Decimal(15, 2)
  dataLancamento        DateTime
  // Datas opcionais do lançamento (formulário rico): vencimento e competência.
  dataVencimento        DateTime?
  dataCompetencia       DateTime?
  contaBancariaId       String
  naturezaFinanceiraId  String?
  centroCustoId         String?
  contaReceberId        String?
  contaPagarId          String?
  conciliado            Boolean               @default(false)
  transferenciaParId    String?               @unique
  favorecido            String?
  observacoes           String?
  createdAt             DateTime              @default(now())
  contaBancaria         ContaBancaria         @relation(fields: [contaBancariaId], references: [id])
  naturezaFinanceira    NaturezaFinanceira?   @relation(fields: [naturezaFinanceiraId], references: [id])
  centroCusto           CentroCusto?          @relation(fields: [centroCustoId], references: [id])
  contaPagar            ContaPagar?           @relation(fields: [contaPagarId], references: [id])
  contaReceber          ContaReceber?         @relation(fields: [contaReceberId], references: [id])
  transferenciaPar      LancamentoFinanceiro? @relation("Transferencia", fields: [transferenciaParId], references: [id])
  transferenciaParDe    LancamentoFinanceiro? @relation("Transferencia")
  linhaOFX              LinhaOFX?

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@index([dataLancamento])
  @@index([tipo])
  @@index([contaBancariaId])
  @@index([naturezaFinanceiraId])
  @@index([empresaId])
  @@map("LancamentoCaixa")
}

model ImportacaoOFX {
  id              String        @id @default(cuid())
  empresaId       String        @default("emp_tramontin")
  contaBancariaId String
  nomeArquivo     String?
  dataImportacao  DateTime      @default(now())
  totalLinhas     Int           @default(0)
  createdAt       DateTime      @default(now())
  contaBancaria   ContaBancaria @relation(fields: [contaBancariaId], references: [id])
  linhas          LinhaOFX[]

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@index([contaBancariaId])
  @@index([empresaId])
}

model LinhaOFX {
  id                     String                @id @default(cuid())
  importacaoId           String
  fitId                  String?
  data                   DateTime
  valor                  Decimal               @db.Decimal(15, 2)
  descricao              String?
  lancamentoConciliadoId String?               @unique
  createdAt              DateTime              @default(now())
  importacao             ImportacaoOFX         @relation(fields: [importacaoId], references: [id], onDelete: Cascade)
  lancamentoConciliado   LancamentoFinanceiro? @relation(fields: [lancamentoConciliadoId], references: [id])

  @@index([importacaoId])
}

model LocalEstoque {
  id                   String                  @id @default(cuid())
  empresaId            String                  @default("emp_tramontin")
  nome                 String
  descricao            String?
  ativo                Boolean                 @default(true)
  // Categorias de produto que este local aceita. Vazio = aceita qualquer
  // produto (comportamento legado). Preenchido = só entram produtos cuja
  // categoriaEstoque esteja na lista.
  categoriasAceitas    CategoriaEstoque[]
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  filialId             String?
  enderecos            EnderecoEstoque[]
  estoqueItens         EstoqueItem[]
  filial               Filial?                 @relation(fields: [filialId], references: [id])
  movimentacoes        MovimentacaoEstoque[]
  necessidadesCompra   NecessidadeCompra[]
  docEntradaItens      ConferenciaCompraItem[]
  docEntradas          ConferenciaCompra[]
  requisicoesMateriais RequisicaoMaterial[]   @relation("RM_LocalOrigem")
  requisicoesDestino   RequisicaoMaterial[]   @relation("RM_LocalDestino")
  inventariosMateriais InventarioMaterial[]
  minutas              Minuta[]
  contasContabeis      ContaContabil[]
  empresa              Empresa                 @relation(fields: [empresaId], references: [id])

  @@index([empresaId])
}

model LoteMovimentacao {
  id               String                  @id @default(cuid())
  empresaId        String                  @default("emp_tramontin")
  numero           String
  tipo             TipoMovimentacaoEstoque
  documento        String?
  observacoes      String?
  dataMovimentacao DateTime?
  createdAt        DateTime                @default(now())
  itens            MovimentacaoEstoque[]
  empresa          Empresa                 @relation(fields: [empresaId], references: [id])

  @@unique([empresaId, numero])
  @@index([empresaId])
}

model MovimentacaoEstoque {
  id                String                  @id @default(cuid())
  empresaId         String                  @default("emp_tramontin")
  itemId            String
  tipo              TipoMovimentacaoEstoque
  quantidade        Decimal                 @db.Decimal(15, 3)
  saldoAntes        Decimal                 @db.Decimal(15, 3)
  saldoDepois       Decimal                 @db.Decimal(15, 3)
  documento         String?
  observacoes       String?
  criadoPor         String?
  pedidoVendaItemId String?
  ordemProducaoId   String?
  // Data de NEGÓCIO da movimentação (date-only, UTC midnight) — ex.: a dt. de
  // emissão do documento de entrada. Independe do createdAt (timestamp de
  // auditoria). Exibida nas Movimentações; cai no createdAt quando ausente.
  data              DateTime?
  createdAt         DateTime                @default(now())
  conferenciaItemId String?
  localEstoqueId    String?
  loteId            String?
  valorUnitario     Decimal?                @db.Decimal(15, 4)
  unidadeId         String?
  clienteDonoId     String? // null = estoque próprio; preenchido = movimentação de mercadoria de terceiro
  conferenciaItem   ConferenciaCompraItem?  @relation(fields: [conferenciaItemId], references: [id])
  item              Item                    @relation(fields: [itemId], references: [id])
  localEstoque      LocalEstoque?           @relation(fields: [localEstoqueId], references: [id])
  lote              LoteMovimentacao?       @relation(fields: [loteId], references: [id])
  pedidoVendaItem   PedidoVendaItem?        @relation(fields: [pedidoVendaItemId], references: [id])
  ordemProducao     OrdemProducao?          @relation(fields: [ordemProducaoId], references: [id])
  unidade           Unidade?                @relation(fields: [unidadeId], references: [id])
  clienteDono       Cliente?                @relation("MovimentacoesTerceiros", fields: [clienteDonoId], references: [id])
  // Venda à ordem (triangular): liga os 3 movimentos virtuais (saída origem +
  // entrada/saída na empresa da venda) ao pedido de venda que os originou.
  vendaOrdemId      String?
  vendaOrdem        PedidoVenda?            @relation("MovimentacoesVendaOrdem", fields: [vendaOrdemId], references: [id])
  // Devolução de venda: tag do movimento (ENTRADA de volta) gerado por uma devolução.
  devolucaoId       String?

  empresa Empresa @relation(fields: [empresaId], references: [id])

  @@index([createdAt])
  @@index([itemId])
  @@index([loteId])
  @@index([tipo])
  @@index([clienteDonoId])
  @@index([ordemProducaoId])
  @@index([vendaOrdemId])
  @@index([devolucaoId])
  @@index([empresaId])
}

model MovimentacaoComodato {
